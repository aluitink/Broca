@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using Broca.ActivityPub.Components
@using static Broca.ActivityPub.Components.ActivityCalendar

<div class="fluent-activity-calendar @CssClass">
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
        <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" VerticalAlignment="VerticalAlignment.Center">
            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@Title</FluentLabel>
            @if (ShowLegend)
            {
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="4" VerticalAlignment="VerticalAlignment.Center">
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral" Style="font-size: 0.75rem;">Less</FluentLabel>
                    @for (int i = 0; i <= 4; i++)
                    {
                        <FluentTooltip Text="@GetLevelLabel(i)" Anchor="@($"legend-{i}")">
                            <div id="@($"legend-{i}")" class="legend-box level-@i" style="width: 12px; height: 12px; border-radius: 2px;"></div>
                        </FluentTooltip>
                    }
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral" Style="font-size: 0.75rem;">More</FluentLabel>
                </FluentStack>
            }
        </FluentStack>
        
        <div class="calendar-grid-container" style="overflow-x: auto;">
            <div class="calendar-grid" style="display: grid; gap: 3px;">
                @if (ShowMonthLabels)
                {
                    <div class="month-labels" style="display: flex; gap: 3px; margin-bottom: 4px;">
                        @foreach (var month in Context.MonthLabels)
                        {
                            <FluentLabel Typo="Typography.Body" 
                                        Color="Color.Neutral" 
                                        Style="@($"min-width: {month.Span * 15}px; text-align: left; font-size: 0.75rem;")">
                                @month.Name
                            </FluentLabel>
                        }
                    </div>
                }
                
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="3">
                    @if (ShowDayLabels)
                    {
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="3" Style="padding-right: 4px;">
                            @foreach (var day in new[] { "", "Mon", "", "Wed", "", "Fri", "" })
                            {
                                <FluentLabel Typo="Typography.Body" 
                                            Color="Color.Neutral" 
                                            Style="height: 12px; width: 30px; line-height: 12px; font-size: 10px;">
                                    @day
                                </FluentLabel>
                            }
                        </FluentStack>
                    }
                    
                    <div class="days-grid" style="display: grid; grid-template-rows: repeat(7, 12px); grid-auto-flow: column; gap: 3px;">
                        @foreach (var day in Context.Days)
                        {
                            <FluentTooltip Text="@GetDayTooltip(day)" Anchor="@GetDayId(day)">
                                <div id="@GetDayId(day)" 
                                     class="day-cell level-@day.Level" 
                                     @onclick="@(() => OnDayClick(day))"
                                     style="@GetDayStyle(day)">
                                </div>
                            </FluentTooltip>
                        }
                    </div>
                </FluentStack>
            </div>
        </div>
    </FluentStack>
</div>

<style>
    .fluent-activity-calendar .day-cell {
        width: 12px;
        height: 12px;
        border-radius: 2px;
        cursor: pointer;
        transition: transform 0.1s ease;
    }
    
    .fluent-activity-calendar .day-cell:hover {
        transform: scale(1.1);
        outline: 1px solid var(--neutral-stroke-strong);
    }
    
    .fluent-activity-calendar .day-cell.level-0,
    .fluent-activity-calendar .legend-box.level-0 {
        background-color: var(--neutral-layer-3);
    }
    
    .fluent-activity-calendar .day-cell.level-1,
    .fluent-activity-calendar .legend-box.level-1 {
        background-color: var(--accent-fill-rest);
        opacity: 0.25;
    }
    
    .fluent-activity-calendar .day-cell.level-2,
    .fluent-activity-calendar .legend-box.level-2 {
        background-color: var(--accent-fill-rest);
        opacity: 0.5;
    }
    
    .fluent-activity-calendar .day-cell.level-3,
    .fluent-activity-calendar .legend-box.level-3 {
        background-color: var(--accent-fill-rest);
        opacity: 0.75;
    }
    
    .fluent-activity-calendar .day-cell.level-4,
    .fluent-activity-calendar .legend-box.level-4 {
        background-color: var(--accent-fill-rest);
        opacity: 1;
    }
</style>

@code {
    [Parameter]
    public CalendarContext Context { get; set; } = null!;

    [Parameter]
    public string? CssClass { get; set; }

    [Parameter]
    public string Title { get; set; } = "Activity";

    [Parameter]
    public bool ShowMonthLabels { get; set; } = true;

    [Parameter]
    public bool ShowDayLabels { get; set; } = true;

    [Parameter]
    public bool ShowLegend { get; set; } = true;

    [Parameter]
    public EventCallback<CalendarDay> OnDayClicked { get; set; }

    private string GetDayId(CalendarDay day)
    {
        return $"day-{day.Date:yyyyMMdd}";
    }

    private string GetDayTooltip(CalendarDay day)
    {
        var dateStr = day.Date.ToString("MMM dd, yyyy");
        return day.Count == 0 
            ? $"{dateStr}: No activity" 
            : $"{dateStr}: {day.Count} {(day.Count == 1 ? "post" : "posts")}";
    }

    private string GetDayStyle(CalendarDay day)
    {
        return string.Empty;
    }

    private string GetLevelLabel(int level)
    {
        return level switch
        {
            0 => "No activity",
            1 => "Low activity",
            2 => "Moderate activity",
            3 => "High activity",
            4 => "Very high activity",
            _ => ""
        };
    }

    private async Task OnDayClick(CalendarDay day)
    {
        if (OnDayClicked.HasDelegate)
        {
            await OnDayClicked.InvokeAsync(day);
        }
    }
}

@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using Microsoft.AspNetCore.Components.Forms
@using System.Net.Http
@using System.Net.Http.Headers
@using Broca.ActivityPub.Components

@*
    FluentMediaUpload - A Fluent UI implementation of MediaUpload component.
*@

<div class="fluent-media-upload @CssClass">
    @if (ShowUploadArea)
    {
        <div class="upload-area @(IsDragging ? "dragging" : "")"
             @ondragenter="HandleDragEnter"
             @ondragover="HandleDragOver"
             @ondragleave="HandleDragLeave"
             @ondrop="HandleDrop">
            
            <div class="upload-content">
                @if (UploadAreaContent != null)
                {
                    @UploadAreaContent
                }
                else
                {
                    <FluentIcon Value="@(new Icons.Regular.Size48.Apps())" Color="Color.Neutral" Class="upload-icon" />
                    <FluentLabel Typo="Typography.Body">
                        <strong style="color: var(--accent-fill-rest);">Drag and drop files here</strong> or click to browse
                    </FluentLabel>
                    @if (!string.IsNullOrEmpty(AcceptedFileTypes))
                    {
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral" Style="margin-top: 0.25rem;">
                            Accepted: @GetAcceptedTypesDisplay()
                        </FluentLabel>
                    }
                    @if (MaxFileSizeMB > 0)
                    {
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">
                            Max size: @MaxFileSizeMB MB per file
                        </FluentLabel>
                    }
                }
            </div>

            <InputFile OnChange="HandleFileSelected"
                       multiple="@AllowMultiple"
                       accept="@AcceptedFileTypes"
                       class="upload-input" />
        </div>
    }

    @if (uploadedFiles.Any() || uploadingFiles.Any())
    {
        <FluentStack Orientation="Orientation.Vertical" Style="margin-top: 1rem;">
            @foreach (var file in uploadingFiles)
            {
                <FluentCard Class="upload-item uploading">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Top">
                        <div class="upload-item-preview">
                            @if (file.PreviewUrl != null)
                            {
                                <img src="@file.PreviewUrl" alt="Preview" class="preview-image" />
                            }
                            else
                            {
                                <div class="preview-placeholder">
                                    <FluentIcon Value="@GetFileIconFluent(file.MimeType)" Color="Color.Neutral" />
                                </div>
                            }
                        </div>
                        
                        <FluentStack Orientation="Orientation.Vertical" Style="flex: 1;" VerticalGap="4">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold" Title="@file.FileName">
                                @file.FileName
                            </FluentLabel>
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">
                                @FormatFileSize(file.Size)
                            </FluentLabel>
                            
                            @if (file.Error != null)
                            {
                                <FluentLabel Typo="Typography.Body" Color="Color.Error">
                                    @file.Error
                                </FluentLabel>
                            }
                            else if (file.Progress < 100)
                            {
                                <FluentProgressRing Value="@file.Progress" Min="0" Max="100" Width="200px" />
                                <FluentLabel Typo="Typography.Body" Color="Color.Accent">
                                    Uploading @file.Progress%
                                </FluentLabel>
                            }
                        </FluentStack>

                        <FluentStack Orientation="Orientation.Horizontal">
                            @if (file.Error != null && AllowRetry)
                            {
                                <FluentButton Appearance="Appearance.Lightweight" 
                                            IconOnly="true"
                                            OnClick="() => RetryUpload(file)" 
                                            Title="Retry upload"
                                            aria-label="Retry upload">
                                    <FluentIcon Value="@(new Icons.Regular.Size20.ArrowClockwise())" />
                                </FluentButton>
                            }
                            <FluentButton Appearance="Appearance.Lightweight" 
                                        IconOnly="true"
                                        OnClick="() => RemoveUploadingFile(file)" 
                                        Title="Remove"
                                        aria-label="Remove">
                                <FluentIcon Value="@(new Icons.Regular.Size20.Dismiss())" />
                            </FluentButton>
                        </FluentStack>
                    </FluentStack>
                </FluentCard>
            }

            @foreach (var file in uploadedFiles)
            {
                <FluentCard Class="upload-item uploaded">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Top">
                        <div class="upload-item-preview">
                            @if (file.ThumbnailUrl != null || file.Url != null)
                            {
                                <img src="@(file.ThumbnailUrl ?? file.Url)" alt="@file.AltText" class="preview-image" />
                            }
                            else
                            {
                                <div class="preview-placeholder">
                                    <FluentIcon Value="@GetFileIconFluent(file.MimeType)" Color="Color.Neutral" />
                                </div>
                            }
                        </div>
                        
                        <FluentStack Orientation="Orientation.Vertical" Style="flex: 1;" VerticalGap="4">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold" Title="@file.FileName">
                                @file.FileName
                            </FluentLabel>
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">
                                @FormatFileSize(file.Size)
                            </FluentLabel>
                            
                            @if (ShowAltTextInput)
                            {
                                <FluentTextField 
                                    Placeholder="Add alt text (for accessibility)" 
                                    Value="@file.AltText"
                                    ValueChanged="@((string? value) => UpdateAltText(file, value))" 
                                    MaxLength="@MaxAltTextLength"
                                    Style="width: 100%;" />
                            }
                        </FluentStack>

                        <FluentStack Orientation="Orientation.Horizontal">
                            <FluentButton Appearance="Appearance.Lightweight" 
                                        IconOnly="true"
                                        OnClick="() => RemoveUploadedFile(file)" 
                                        Title="Remove"
                                        aria-label="Remove">
                                <FluentIcon Value="@(new Icons.Regular.Size20.Dismiss())" Color="Color.Error" />
                            </FluentButton>
                        </FluentStack>
                    </FluentStack>
                </FluentCard>
            }
        </FluentStack>
    }
</div>

@code {
    private List<UploadingFile> uploadingFiles = new();
    private List<UploadedFile> uploadedFiles = new();
    private bool isDragging = false;

    [Parameter]
    public string AcceptedFileTypes { get; set; } = "image/*,video/*,audio/*";

    [Parameter]
    public int MaxFileSizeMB { get; set; } = 10;

    [Parameter]
    public bool AllowMultiple { get; set; } = true;

    [Parameter]
    public int MaxFiles { get; set; } = 10;

    [Parameter]
    public bool ShowUploadArea { get; set; } = true;

    [Parameter]
    public bool ShowAltTextInput { get; set; } = true;

    [Parameter]
    public int MaxAltTextLength { get; set; } = 1000;

    [Parameter]
    public bool AllowRetry { get; set; } = true;

    [Parameter]
    public RenderFragment? UploadAreaContent { get; set; }

    [Parameter]
    public string? CssClass { get; set; }

    [Parameter]
    public string? UploadUrl { get; set; }

    [Parameter]
    public HttpClient? HttpClient { get; set; }

    [Parameter]
    public EventCallback<List<UploadedFile>> OnFilesUploaded { get; set; }

    [Parameter]
    public EventCallback<UploadedFile> OnFileRemoved { get; set; }

    [Parameter]
    public EventCallback<string> OnValidationError { get; set; }

    private bool IsDragging => isDragging;

    private void HandleDragEnter()
    {
        isDragging = true;
    }

    private void HandleDragOver()
    {
        isDragging = true;
    }

    private void HandleDragLeave()
    {
        isDragging = false;
    }

    private void HandleDrop()
    {
        isDragging = false;
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles(AllowMultiple ? MaxFiles : 1);
        
        if (uploadedFiles.Count + uploadingFiles.Count + files.Count > MaxFiles)
        {
            var error = $"Cannot upload more than {MaxFiles} files";
            await OnValidationError.InvokeAsync(error);
            return;
        }

        foreach (var file in files)
        {
            await ProcessFile(file);
        }
    }

    private async Task ProcessFile(IBrowserFile file)
    {
        var uploadingFile = new UploadingFile
        {
            FileName = file.Name,
            Size = file.Size,
            MimeType = file.ContentType
        };

        if (!ValidateFile(uploadingFile, out var validationError))
        {
            uploadingFile.Error = validationError;
            uploadingFiles.Add(uploadingFile);
            await OnValidationError.InvokeAsync(validationError);
            StateHasChanged();
            return;
        }

        uploadingFiles.Add(uploadingFile);
        StateHasChanged();

        try
        {
            if (uploadingFile.MimeType?.StartsWith("image/") == true)
            {
                var resizedImage = await file.RequestImageFileAsync(file.ContentType, 800, 600);
                await using var stream = resizedImage.OpenReadStream(MaxFileSizeMB * 1024 * 1024);
                var buffer = new byte[stream.Length];
                await stream.ReadAsync(buffer);
                uploadingFile.PreviewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
                StateHasChanged();
            }

            await UploadFile(uploadingFile, file);
        }
        catch (Exception ex)
        {
            uploadingFile.Error = ex.Message;
            uploadingFile.Progress = 0;
            StateHasChanged();
        }
    }

    private bool ValidateFile(UploadingFile file, out string? error)
    {
        error = null;

        var maxBytes = MaxFileSizeMB * 1024 * 1024;
        if (file.Size > maxBytes)
        {
            error = $"{file.FileName}: File size exceeds {MaxFileSizeMB}MB limit";
            return false;
        }

        if (!string.IsNullOrEmpty(AcceptedFileTypes))
        {
            var acceptedTypes = AcceptedFileTypes.Split(',').Select(t => t.Trim()).ToList();
            var isAccepted = acceptedTypes.Any(type =>
            {
                if (type.EndsWith("/*"))
                {
                    var prefix = type.Substring(0, type.Length - 2);
                    return file.MimeType?.StartsWith(prefix) == true;
                }
                return file.MimeType == type;
            });

            if (!isAccepted)
            {
                error = $"{file.FileName}: File type not accepted";
                return false;
            }
        }

        return true;
    }

    private async Task UploadFile(UploadingFile uploadingFile, IBrowserFile file)
    {
        if (HttpClient == null || string.IsNullOrEmpty(UploadUrl))
        {
            uploadingFile.Error = "Upload not configured";
            return;
        }

        try
        {
            using var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(file.OpenReadStream(MaxFileSizeMB * 1024 * 1024));
            fileContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            uploadingFile.Progress = 10;
            StateHasChanged();

            var response = await HttpClient.PostAsync(UploadUrl, content);

            uploadingFile.Progress = 90;
            StateHasChanged();

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<UploadResponse>();
                
                var uploadedFile = new UploadedFile
                {
                    FileName = uploadingFile.FileName,
                    Size = uploadingFile.Size,
                    MimeType = uploadingFile.MimeType,
                    Url = result?.Url ?? string.Empty,
                    ThumbnailUrl = uploadingFile.PreviewUrl,
                    BlobId = result?.BlobId
                };

                uploadingFiles.Remove(uploadingFile);
                uploadedFiles.Add(uploadedFile);
                
                uploadingFile.Progress = 100;
                StateHasChanged();

                if (OnFilesUploaded.HasDelegate)
                {
                    await OnFilesUploaded.InvokeAsync(uploadedFiles);
                }
            }
            else
            {
                uploadingFile.Error = $"Upload failed: {response.StatusCode}";
                uploadingFile.Progress = 0;
            }
        }
        catch (Exception ex)
        {
            uploadingFile.Error = $"Upload failed: {ex.Message}";
            uploadingFile.Progress = 0;
        }

        StateHasChanged();
    }

    private void RetryUpload(UploadingFile file)
    {
        file.Error = null;
        file.Progress = 0;
        StateHasChanged();
    }

    private void RemoveUploadingFile(UploadingFile file)
    {
        uploadingFiles.Remove(file);
        StateHasChanged();
    }

    private async Task RemoveUploadedFile(UploadedFile file)
    {
        uploadedFiles.Remove(file);
        
        if (OnFileRemoved.HasDelegate)
        {
            await OnFileRemoved.InvokeAsync(file);
        }
        
        StateHasChanged();
    }

    private void UpdateAltText(UploadedFile file, string? altText)
    {
        file.AltText = altText;
        
        if (OnFilesUploaded.HasDelegate)
        {
            _ = OnFilesUploaded.InvokeAsync(uploadedFiles);
        }
    }

    private string GetAcceptedTypesDisplay()
    {
        var types = AcceptedFileTypes.Split(',').Select(t => t.Trim()).ToList();
        var display = new List<string>();
        
        foreach (var type in types)
        {
            if (type == "image/*") display.Add("Images");
            else if (type == "video/*") display.Add("Videos");
            else if (type == "audio/*") display.Add("Audio");
            else display.Add(type.Replace("image/", "").Replace("video/", "").Replace("audio/", "").ToUpper());
        }
        
        return string.Join(", ", display.Distinct());
    }

    private Icon GetFileIconFluent(string? mimeType)
    {
        if (mimeType == null) return new Icons.Regular.Size24.Document();
        if (mimeType.StartsWith("image/")) return new Icons.Regular.Size24.Image();
        if (mimeType.StartsWith("video/")) return new Icons.Regular.Size24.Video();
        if (mimeType.StartsWith("audio/")) return new Icons.Regular.Size24.MusicNote2();
        return new Icons.Regular.Size24.Document();
    }

    private string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    public List<UploadedFile> GetUploadedFiles() => uploadedFiles;

    public void ClearFiles()
    {
        uploadedFiles.Clear();
        uploadingFiles.Clear();
        StateHasChanged();
    }

    public class UploadingFile
    {
        public string FileName { get; set; } = string.Empty;
        public long Size { get; set; }
        public string? MimeType { get; set; }
        public string? PreviewUrl { get; set; }
        public int Progress { get; set; }
        public string? Error { get; set; }
    }

    public class UploadedFile
    {
        public string FileName { get; set; } = string.Empty;
        public long Size { get; set; }
        public string? MimeType { get; set; }
        public string Url { get; set; } = string.Empty;
        public string? ThumbnailUrl { get; set; }
        public string? BlobId { get; set; }
        public string? AltText { get; set; }
    }

    private class UploadResponse
    {
        public string? Url { get; set; }
        public string? BlobId { get; set; }
        public string? ContentType { get; set; }
    }
}

@page "/relationships"
@using Broca.Web.Services
@using Broca.ActivityPub.Components
@using Broca.ActivityPub.Core.Interfaces
@inject AuthenticationStateService AuthState
@inject NavigationManager Navigation
@inject IActivityPubClient Client

<PageTitle>Relationships - Broca</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
            <FluentLabel Typo="Typography.Subject">Authentication Required</FluentLabel>
            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Please login to view your relationships.</FluentLabel>
            <FluentButton Appearance="Appearance.Accent" OnClick="@(() => Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString("/relationships")}"))">
                Login
            </FluentButton>
        </FluentStack>
    </FluentCard>
}
else
{
    <div class="relationships-container">
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="4" Class="relationships-header">
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center">
                <FluentIcon Value="@(new Icons.Regular.Size24.People())" Color="Color.Accent" />
                <FluentLabel Typo="Typography.PageTitle">Relationships</FluentLabel>
            </FluentStack>
            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Manage your followers and following</FluentLabel>
        </FluentStack>

        <FluentTabs>
            <FluentTab Label="Followers">
                <div class="tab-content">
                    @if (_followersUrl != null)
                    {
                        <FollowersList FollowersUrl="@_followersUrl"
                                      PageSize="20"
                                      UseVirtualization="true"
                                      ShowFollowButton="true"
                                      Title="">
                            <ActorTemplate Context="follower">
                                <FluentCard Class="actor-card">
                                    <ActorProfile ActorUri="@(new Uri(follower.Id ?? string.Empty))" ShowFollowButton="true" />
                                </FluentCard>
                            </ActorTemplate>
                            <EmptyTemplate>
                                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                                             Style="padding: 3rem 2rem; text-align: center;" VerticalGap="16">
                                    <FluentIcon Value="@(new Icons.Regular.Size48.People())" Color="Color.Neutral" />
                                    <FluentLabel Typo="Typography.Subject">No followers yet</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">When others follow you, they will appear here.</FluentLabel>
                                </FluentStack>
                            </EmptyTemplate>
                            <ErrorTemplate Context="error">
                                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                                             Style="padding: 3rem 2rem; text-align: center;" VerticalGap="16">
                                    <FluentIcon Value="@(new Icons.Regular.Size48.Warning())" Color="Color.Error" />
                                    <FluentLabel Typo="Typography.Subject">Failed to load followers</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@error</FluentLabel>
                                </FluentStack>
                            </ErrorTemplate>
                        </FollowersList>
                    }
                    else
                    {
                        <FluentCard>
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Unable to determine followers URL.</FluentLabel>
                        </FluentCard>
                    }
                </div>
            </FluentTab>

            <FluentTab Label="Following">
                <div class="tab-content">
                    @if (_followingUrl != null)
                    {
                        <FollowingList FollowingUrl="@_followingUrl"
                                      PageSize="20"
                                      UseVirtualization="true"
                                      ShowUnfollowButton="true"
                                      Title="">
                            <ActorTemplate Context="following">
                                <FluentCard Class="actor-card">
                                    <ActorProfile ActorUri="@(new Uri(following.Id ?? string.Empty))" ShowFollowButton="true" />
                                </FluentCard>
                            </ActorTemplate>
                            <EmptyTemplate>
                                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                                             Style="padding: 3rem 2rem; text-align: center;" VerticalGap="16">
                                    <FluentIcon Value="@(new Icons.Regular.Size48.PersonAdd())" Color="Color.Neutral" />
                                    <FluentLabel Typo="Typography.Subject">Not following anyone yet</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Start following other actors to see them here.</FluentLabel>
                                </FluentStack>
                            </EmptyTemplate>
                            <ErrorTemplate Context="error">
                                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                                             Style="padding: 3rem 2rem; text-align: center;" VerticalGap="16">
                                    <FluentIcon Value="@(new Icons.Regular.Size48.Warning())" Color="Color.Error" />
                                    <FluentLabel Typo="Typography.Subject">Failed to load following</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@error</FluentLabel>
                                </FluentStack>
                            </ErrorTemplate>
                        </FollowingList>
                    }
                    else
                    {
                        <FluentCard>
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Unable to determine following URL.</FluentLabel>
                        </FluentCard>
                    }
                </div>
            </FluentTab>

            <FluentTab Label="Blocks">
                <div class="tab-content">
                    @if (_blocksUrl != null)
                    {
                        <RelationshipsList CollectionUrl="@_blocksUrl"
                                           Title="Blocked"
                                           ActionLabel="Unblock"
                                           PageSize="20"
                                           OnActionClick="@HandleUnblockAsync">
                            <ActorTemplate Context="actor">
                                <FluentCard Class="actor-card">
                                    <ActorRenderer Actor="@actor" />
                                    <FluentButton Appearance="Appearance.Outline"
                                                  OnClick="@(() => HandleUnblockAsync(actor.Id ?? string.Empty))">
                                        Unblock
                                    </FluentButton>
                                </FluentCard>
                            </ActorTemplate>
                            <EmptyTemplate>
                                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                                             Style="padding: 3rem 2rem; text-align: center;" VerticalGap="16">
                                    <FluentIcon Value="@(new Icons.Regular.Size48.Prohibited())" Color="Color.Neutral" />
                                    <FluentLabel Typo="Typography.Subject">No blocked accounts</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Accounts you block will appear here.</FluentLabel>
                                </FluentStack>
                            </EmptyTemplate>
                            <ErrorTemplate Context="error">
                                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                                             Style="padding: 3rem 2rem; text-align: center;" VerticalGap="16">
                                    <FluentIcon Value="@(new Icons.Regular.Size48.Warning())" Color="Color.Error" />
                                    <FluentLabel Typo="Typography.Subject">Failed to load blocks</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@error</FluentLabel>
                                </FluentStack>
                            </ErrorTemplate>
                        </RelationshipsList>
                    }
                    else
                    {
                        <FluentCard>
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Unable to determine blocks URL.</FluentLabel>
                        </FluentCard>
                    }
                </div>
            </FluentTab>

            <FluentTab Label="Mutes">
                <div class="tab-content">
                    @if (_mutesUrl != null)
                    {
                        <RelationshipsList CollectionUrl="@_mutesUrl"
                                           Title="Muted"
                                           ActionLabel="Unmute"
                                           PageSize="20"
                                           OnActionClick="@HandleUnmuteAsync">
                            <ActorTemplate Context="actor">
                                <FluentCard Class="actor-card">
                                    <ActorRenderer Actor="@actor" />
                                    <FluentButton Appearance="Appearance.Outline"
                                                  OnClick="@(() => HandleUnmuteAsync(actor.Id ?? string.Empty))">
                                        Unmute
                                    </FluentButton>
                                </FluentCard>
                            </ActorTemplate>
                            <EmptyTemplate>
                                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                                             Style="padding: 3rem 2rem; text-align: center;" VerticalGap="16">
                                    <FluentIcon Value="@(new Icons.Regular.Size48.SpeakerMute())" Color="Color.Neutral" />
                                    <FluentLabel Typo="Typography.Subject">No muted accounts</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Accounts you mute will appear here.</FluentLabel>
                                </FluentStack>
                            </EmptyTemplate>
                            <ErrorTemplate Context="error">
                                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                                             Style="padding: 3rem 2rem; text-align: center;" VerticalGap="16">
                                    <FluentIcon Value="@(new Icons.Regular.Size48.Warning())" Color="Color.Error" />
                                    <FluentLabel Typo="Typography.Subject">Failed to load mutes</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@error</FluentLabel>
                                </FluentStack>
                            </ErrorTemplate>
                        </RelationshipsList>
                    }
                    else
                    {
                        <FluentCard>
                            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Unable to determine mutes URL.</FluentLabel>
                        </FluentCard>
                    }
                </div>
            </FluentTab>
        </FluentTabs>
    </div>
}

@code {
    private Uri? _followersUrl;
    private Uri? _followingUrl;
    private Uri? _blocksUrl;
    private Uri? _mutesUrl;

    protected override void OnInitialized()
    {
        AuthState.AuthenticationStateChanged += OnAuthStateChanged;
        UpdateCollectionUrls();
    }

    private void OnAuthStateChanged(object? sender, bool isAuthenticated)
    {
        UpdateCollectionUrls();
        InvokeAsync(StateHasChanged);
    }

    private void UpdateCollectionUrls()
    {
        _followersUrl = AuthState.GetFollowersUrl();
        _followingUrl = AuthState.GetFollowingUrl();

        if (AuthState.CurrentActorId != null && Uri.TryCreate(AuthState.CurrentActorId, UriKind.Absolute, out var actorUri))
        {
            _blocksUrl = new Uri(actorUri, "blocked");
            _mutesUrl = new Uri(actorUri, "muted");
        }
    }

    private async Task HandleUnblockAsync(string actorId)
    {
        if (string.IsNullOrEmpty(actorId)) return;
        try
        {
            var blockActivity = Client.CreateActivityBuilder().Block(actorId);
            var undoActivity = Client.CreateActivityBuilder().Undo(blockActivity);
            await Client.PostToOutboxAsync(undoActivity);
        }
        catch
        {
            // Silently fail - user can retry
        }
    }

    private async Task HandleUnmuteAsync(string actorId)
    {
        if (string.IsNullOrEmpty(actorId)) return;
        try
        {
            // Mutes are server-specific; send an Undo{Block} or equivalent
            // For Broca, we post a server-defined undo-mute activity
            var undoActivity = Client.CreateActivityBuilder().UndoByReference(actorId);
            await Client.PostToOutboxAsync(undoActivity);
        }
        catch
        {
            // Silently fail - user can retry
        }
    }

    public void Dispose()
    {
        AuthState.AuthenticationStateChanged -= OnAuthStateChanged;
    }
}

<style>
    .relationships-container {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        max-width: 1000px;
        margin: 0 auto;
    }

    .relationships-header {
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--neutral-stroke-divider-rest);
    }

    .tab-content {
        padding: 1rem 0;
    }

    .actor-card {
        margin-bottom: 1rem;
    }
</style>

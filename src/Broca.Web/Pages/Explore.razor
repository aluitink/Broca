@page "/explore"
@using Broca.Web.Services
@using Broca.ActivityPub.Components
@inject AuthenticationStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Explore - Broca</PageTitle>

<div class="explore-container">
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="4" Class="explore-header">
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center">
            <FluentIcon Value="@(new Icons.Regular.Size24.Search())" Color="Color.Accent" />
            <FluentLabel Typo="Typography.PageTitle">Explore the Fediverse</FluentLabel>
        </FluentStack>
        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Search for and discover actors across the ActivityPub network</FluentLabel>
    </FluentStack>

    <FluentCard Class="search-card">
        <ActorBrowser OnActorFound="@HandleActorFound">
            <SearchTemplate Context="searchContext">
                <div class="search-input-container">
                    <FluentTextField 
                        @bind-Value="searchContext.Query" 
                        Placeholder="Enter actor handle (e.g., user@mastodon.social) or actor URL"
                        Style="flex: 1;"
                        Immediate="true">
                        <FluentIcon Value="@(new Icons.Regular.Size20.Search())" Slot="start" />
                    </FluentTextField>
                    <FluentButton 
                        Appearance="Appearance.Accent" 
                        OnClick="@searchContext.Execute">
                        Search
                    </FluentButton>
                </div>
            </SearchTemplate>
            <LoadingTemplate>
                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                             Style="padding: 2rem; text-align: center;" VerticalGap="16">
                    <FluentProgressRing />
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Searching for actor...</FluentLabel>
                </FluentStack>
            </LoadingTemplate>
            <ErrorTemplate Context="error">
                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                             Style="padding: 2rem; text-align: center;" VerticalGap="16">
                    <FluentIcon Value="@(new Icons.Regular.Size48.Warning())" Color="Color.Error" />
                    <FluentLabel Typo="Typography.Subject">Search failed</FluentLabel>
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@error</FluentLabel>
                </FluentStack>
            </ErrorTemplate>
            <ProfileTemplate Context="actor">
                <FluentCard Class="profile-result">
                    <ActorProfile ActorUri="@(new Uri(actor.Id ?? string.Empty))" ShowFollowButton="true" />
                </FluentCard>
            </ProfileTemplate>
        </ActorBrowser>
    </FluentCard>

    @if (_recentSearches.Any())
    {
        <FluentCard Class="recent-searches">
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8"
                         VerticalAlignment="VerticalAlignment.Center" Style="margin-bottom: 1rem;">
                <FluentIcon Value="@(new Icons.Regular.Size20.History())" />
                <FluentLabel Typo="Typography.Subject">Recent Searches</FluentLabel>
            </FluentStack>
            <div class="search-history">
                @foreach (var search in _recentSearches.Take(5))
                {
                    <div class="history-item">
                        <span>@search</span>
                        <FluentButton 
                            Appearance="Appearance.Lightweight" 
                            OnClick="@(() => Navigation.NavigateTo($"/profile?actor={Uri.EscapeDataString(search)}"))">
                            View
                        </FluentButton>
                    </div>
                }
            </div>
        </FluentCard>
    }

    @if (!AuthState.IsAuthenticated)
    {
        <FluentMessageBar Intent="MessageIntent.Info">
            <FluentIcon Value="@(new Icons.Regular.Size20.Info())" Slot="start" />
            Sign in to follow actors and interact with content
        </FluentMessageBar>
    }
</div>

@code {
    private List<string> _recentSearches = new();

    private Task HandleActorFound(KristofferStrube.ActivityStreams.Object actor)
    {
        if (actor?.Id != null && !_recentSearches.Contains(actor.Id))
        {
            _recentSearches.Insert(0, actor.Id);
            if (_recentSearches.Count > 10)
            {
                _recentSearches.RemoveAt(_recentSearches.Count - 1);
            }
            StateHasChanged();
        }
        return Task.CompletedTask;
    }
}

<style>
    .explore-container {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        max-width: 900px;
        margin: 0 auto;
    }

    .explore-header {
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--neutral-stroke-divider-rest);
    }

    .search-card {
        padding: 1.5rem;
    }

    .search-input-container {
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    .profile-result {
        margin-top: 1.5rem;
    }

    .recent-searches {
        padding: 1.5rem;
    }

    .search-history {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .history-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem;
        background: var(--neutral-layer-2);
        border-radius: var(--control-corner-radius);
    }

    .history-item span {
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: var(--neutral-foreground-rest);
    }

    @@media (max-width: 768px) {
        .search-input-container {
            flex-direction: column;
        }

        .history-item {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.5rem;
        }
    }
</style>


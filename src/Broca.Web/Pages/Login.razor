@page "/login"
@using Broca.Web.Services
@using Broca.ActivityPub.Core.Interfaces
@inject AuthenticationStateService AuthState
@inject NavigationManager Navigation
@inject IActivityPubClient ActivityPubClient

<PageTitle>Login - Broca</PageTitle>

<div class="login-container">
    <FluentCard Class="login-card">
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="12" Style="margin-bottom: 1.5rem;">
            <FluentLabel Typo="Typography.PageTitle">Login to Broca</FluentLabel>
            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Enter your credentials to access your ActivityPub account</FluentLabel>
        </FluentStack>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <FluentMessageBar Intent="MessageIntent.Error" Class="login-error">
                @_errorMessage
            </FluentMessageBar>
        }

        <EditForm Model="@_loginModel" OnValidSubmit="@HandleLoginAsync">
            <DataAnnotationsValidator />
            
            <div class="form-field">
                <FluentTextField 
                    @bind-Value="_loginModel.ActorId"
                    Label="Username"
                    Placeholder="admin or admin@example.com"
                    Required="true"
                    Style="width: 100%;"
                    Disabled="@_isLoading">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Person())" Slot="start" Color="Color.Neutral" />
                </FluentTextField>
                <ValidationMessage For="@(() => _loginModel.ActorId)" />
            </div>

            <div class="form-field">
                <FluentTextField 
                    @bind-Value="_loginModel.ApiKey"
                    Label="API Key"
                    Placeholder="Enter your API key"
                    Type="TextFieldType.Password"
                    Required="true"
                    Style="width: 100%;"
                    Disabled="@_isLoading">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Key())" Slot="start" Color="Color.Neutral" />
                </FluentTextField>
                <ValidationMessage For="@(() => _loginModel.ApiKey)" />
            </div>

            <div class="form-actions">
                <FluentButton 
                    Type="ButtonType.Submit" 
                    Appearance="Appearance.Accent"
                    Loading="@_isLoading"
                    Style="width: 100%;">
                    @if (_isLoading)
                    {
                        <text>Authenticating...</text>
                    }
                    else
                    {
                        <text>Login</text>
                    }
                </FluentButton>
            </div>
        </EditForm>

        <div class="login-info">
            <FluentIcon Value="@(new Icons.Regular.Size20.Info())" Color="Color.Accent" />
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Development Login</FluentLabel>
                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">This is a temporary authentication method using API keys. Full OAuth support will be added in a future release.</FluentLabel>
                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">When you login, your actor profile and private key will be fetched from the server, allowing you to interact with ActivityPub content.</FluentLabel>
            </FluentStack>
        </div>
    </FluentCard>
</div>

@code {
    private LoginModel _loginModel = new();
    private bool _isLoading;
    private string? _errorMessage;

    [Parameter]
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private async Task HandleLoginAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var resolvedActorId = await ResolveActorIdAsync(_loginModel.ActorId!.Trim());
            var success = await AuthState.LoginAsync(resolvedActorId, _loginModel.ApiKey!);

            if (success)
            {
                var destination = string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl;
                Navigation.NavigateTo(destination);
            }
            else
            {
                _errorMessage = "Authentication failed. Please check your username and API key.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Login error: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task<string> ResolveActorIdAsync(string input)
    {
        if (Uri.TryCreate(input, UriKind.Absolute, out _))
            return input;

        if (input.Contains('@'))
        {
            var actor = await ActivityPubClient.GetActorByAliasAsync(input);
            return actor.Id ?? throw new InvalidOperationException($"Actor ID not found for alias '{input}'");
        }

        // Bare username — resolve against the local instance
        var baseUri = new Uri(Navigation.BaseUri);
        var actorUri = new Uri(baseUri, $"ap/users/{Uri.EscapeDataString(input)}");
        return actorUri.ToString();
    }

    private class LoginModel
    {
        public string? ActorId { get; set; }
        public string? ApiKey { get; set; }
    }
}

<style>
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        padding: 20px;
    }

    .login-card {
        max-width: 500px;
        width: 100%;
        padding: 2rem;
    }

    .form-field {
        margin-bottom: 1.5rem;
    }

    .form-actions {
        margin-top: 2rem;
    }

    .login-error {
        margin-bottom: 1.5rem;
    }

    .login-info {
        margin-top: 2rem;
        padding: 1rem;
        background-color: var(--neutral-layer-2);
        border-radius: var(--control-corner-radius);
        display: flex;
        gap: 1rem;
        align-items: flex-start;
    }
</style>

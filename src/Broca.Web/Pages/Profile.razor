@page "/profile"
@using Broca.Web.Services
@using Broca.Web.Components
@inject AuthenticationStateService AuthState
@inject NavigationManager Navigation
@inject HttpClient Http

<PageTitle>Profile - Broca</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
            <FluentLabel Typo="Typography.Subject">Authentication Required</FluentLabel>
            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Please login to view your profile.</FluentLabel>
            <FluentButton Appearance="Appearance.Accent" OnClick="@(() => Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString("/profile")}"))">
                Login
            </FluentButton>
        </FluentStack>
    </FluentCard>
}
else if (AuthState.CurrentActorId != null)
{
    <ActorView @key="@_actorViewKey"
               ActorUri="@(new Uri(AuthState.CurrentActorId))"
               ShowFollowButton="false"
               ShowOpenProfileButton="false"
               ApiBaseUrl="@Http.BaseAddress?.ToString()">
        <AdditionalActions Context="actor">
            <button class="actor-action-button" @onclick="OpenEditDialog">Edit Profile</button>
            <button class="actor-action-button logout-button" @onclick="HandleLogoutAsync">Logout</button>
        </AdditionalActions>
    </ActorView>

    <FluentDialog @bind-Hidden="@_hideEditDialog" Modal="true" TrapFocus="true" PreventScroll="true">
        <FluentDialogHeader>
            <FluentLabel Typo="Typography.Subject">Edit Profile</FluentLabel>
        </FluentDialogHeader>
        <FluentDialogBody>
            <ProfileEditor Actor="@AuthState.CurrentActor"
                           InitiallyEditing="true"
                           OnProfileUpdated="@HandleProfileUpdatedAsync" />
        </FluentDialogBody>
    </FluentDialog>
}

@code {
    private bool _hideEditDialog = true;
    private int _actorViewKey = 0;

    private void OpenEditDialog()
    {
        _hideEditDialog = false;
    }

    private async Task HandleProfileUpdatedAsync(KristofferStrube.ActivityStreams.Actor updatedActor)
    {
        await AuthState.RefreshActorAsync(updatedActor);
        _hideEditDialog = true;
        _actorViewKey++;
        StateHasChanged();
    }

    private async Task HandleLogoutAsync()
    {
        await AuthState.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}

<style>
    .logout-button {
        border-color: var(--error-foreground-rest);
        color: var(--error-foreground-rest);
    }

    .logout-button:hover {
        background-color: var(--error-foreground-rest);
        color: var(--fill-color);
    }
</style>

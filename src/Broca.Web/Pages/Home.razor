@page "/"
@using Broca.Web.Services
@using Broca.ActivityPub.Components
@using Broca.ActivityPub.Core.Interfaces
@implements IDisposable
@inject IActivityPubClient Client
@inject HttpClient Http
@inject AuthenticationStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Home - Broca</PageTitle>

<div class="home-container">
    @if (AuthState.IsAuthenticated)
    {
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="4" Class="home-header">
            <FluentLabel Typo="Typography.PageTitle">Welcome back, @GetDisplayName()</FluentLabel>
        </FluentStack>
    }
    else
    {
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="12" Class="home-header">
            <FluentLabel Typo="Typography.PageTitle">Welcome to Broca</FluentLabel>
            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">A modern ActivityPub client for the decentralized web</FluentLabel>
            <FluentButton Appearance="Appearance.Accent" OnClick="@(() => Navigation.NavigateTo("/login"))">
                Get Started
            </FluentButton>
        </FluentStack>
    }

    @if (_sysInboxUrl != null)
    {
        <ActivityFeed 
            CollectionUrl="@_sysInboxUrl" 
            Title="Public Stream"
            PageSize="20"
            UseVirtualization="true"
            ShowObjects="true"
            ShowRecipients="false">
            <EmptyTemplate>
                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                             Style="padding: 3rem 2rem; text-align: center;" VerticalGap="16">
                    <FluentIcon Value="@(new Icons.Regular.Size48.Globe())" Color="Color.Neutral" />
                    <FluentLabel Typo="Typography.Subject">No public activity yet</FluentLabel>
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Public activities from the server will appear here.</FluentLabel>
                </FluentStack>
            </EmptyTemplate>
            <ErrorTemplate Context="error">
                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                             Style="padding: 3rem 2rem; text-align: center;" VerticalGap="16">
                    <FluentIcon Value="@(new Icons.Regular.Size48.Warning())" Color="Color.Error" />
                    <FluentLabel Typo="Typography.Subject">Failed to load public stream</FluentLabel>
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@error</FluentLabel>
                </FluentStack>
            </ErrorTemplate>
        </ActivityFeed>
    }
    else if (_loading)
    {
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                         Style="padding: 2rem; text-align: center;" VerticalGap="16">
                <FluentProgressRing />
                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Loading public stream...</FluentLabel>
            </FluentStack>
        </FluentCard>
    }
    else if (_error != null)
    {
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                         Style="padding: 2rem; text-align: center;" VerticalGap="16">
                <FluentIcon Value="@(new Icons.Regular.Size48.Warning())" Color="Color.Error" />
                <FluentLabel Typo="Typography.Subject">Unable to load public stream</FluentLabel>
                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@_error</FluentLabel>
            </FluentStack>
        </FluentCard>
    }
</div>

@code {
    private Uri? _sysInboxUrl;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        AuthState.AuthenticationStateChanged += OnAuthStateChanged;
        await ResolveSysInboxUrlAsync();
    }

    private async Task ResolveSysInboxUrlAsync()
    {
        try
        {
            _loading = true;
            var baseAddress = Http.BaseAddress!;
            var sysActorUri = new Uri(baseAddress, "ap/users/sys");
            var sysActor = await Client.GetActorAsync(sysActorUri);
            _sysInboxUrl = sysActor?.Inbox?.Href;
            if (_sysInboxUrl == null)
                _error = "System actor does not have an inbox configured.";
        }
        catch (Exception ex)
        {
            _error = $"Could not load the public stream: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnAuthStateChanged(object? sender, bool isAuthenticated)
    {
        InvokeAsync(StateHasChanged);
    }

    private string GetDisplayName()
    {
        if (AuthState.CurrentActor?.Name?.FirstOrDefault() is string name && !string.IsNullOrWhiteSpace(name))
            return name;
        
        if (AuthState.CurrentActor is Person person && !string.IsNullOrWhiteSpace(person.PreferredUsername))
            return person.PreferredUsername;
        
        return "User";
    }

    public void Dispose()
    {
        AuthState.AuthenticationStateChanged -= OnAuthStateChanged;
    }
}

<style>
    .home-container {
        max-width: 800px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .home-header {
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--neutral-stroke-divider-rest);
    }
</style>

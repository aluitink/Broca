@page "/"
@using Broca.Web.Services
@using Broca.ActivityPub.Components
@using Broca.ActivityPub.Core.Interfaces
@implements IDisposable
@inject IActivityPubClient Client
@inject HttpClient Http
@inject AuthenticationStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Home - Broca</PageTitle>

<div class="home-container">
    @if (AuthState.IsAuthenticated)
    {
        <div class="home-header">
            <h1>Welcome back, @GetDisplayName()</h1>
        </div>
    }
    else
    {
        <div class="home-header">
            <h1>Welcome to Broca</h1>
            <p>A modern ActivityPub client for the decentralized web</p>
            <FluentButton Appearance="Appearance.Accent" OnClick="@(() => Navigation.NavigateTo("/login"))">
                Get Started
            </FluentButton>
        </div>
    }

    @if (_sysInboxUrl != null)
    {
        <ActivityFeed 
            CollectionUrl="@_sysInboxUrl" 
            Title="Public Stream"
            PageSize="20"
            UseVirtualization="true"
            ShowObjects="true"
            ShowRecipients="false">
            <EmptyTemplate>
                <FluentCard Class="empty-state">
                    <FluentIcon Value="@(new Icons.Regular.Size48.Globe())" Color="Color.Neutral" />
                    <h3>No public activity yet</h3>
                    <p>Public activities from the server will appear here.</p>
                </FluentCard>
            </EmptyTemplate>
            <ErrorTemplate Context="error">
                <FluentCard Class="error-state">
                    <FluentIcon Value="@(new Icons.Regular.Size48.Warning())" Color="Color.Error" />
                    <h3>Failed to load public stream</h3>
                    <p>@error</p>
                </FluentCard>
            </ErrorTemplate>
        </ActivityFeed>
    }
    else if (_loading)
    {
        <FluentCard Class="loading-state">
            <FluentProgressRing />
            <p>Loading public stream...</p>
        </FluentCard>
    }
    else if (_error != null)
    {
        <FluentCard Class="error-state">
            <FluentIcon Value="@(new Icons.Regular.Size48.Warning())" Color="Color.Error" />
            <h3>Unable to load public stream</h3>
            <p>@_error</p>
        </FluentCard>
    }
</div>

@code {
    private Uri? _sysInboxUrl;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        AuthState.AuthenticationStateChanged += OnAuthStateChanged;
        await ResolveSysInboxUrlAsync();
    }

    private async Task ResolveSysInboxUrlAsync()
    {
        try
        {
            _loading = true;
            var baseAddress = Http.BaseAddress!;
            var sysActorUri = new Uri(baseAddress, "ap/users/sys");
            var sysActor = await Client.GetActorAsync(sysActorUri);
            _sysInboxUrl = sysActor?.Inbox?.Href;
            if (_sysInboxUrl == null)
                _error = "System actor does not have an inbox configured.";
        }
        catch (Exception ex)
        {
            _error = $"Could not load the public stream: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnAuthStateChanged(object? sender, bool isAuthenticated)
    {
        InvokeAsync(StateHasChanged);
    }

    private string GetDisplayName()
    {
        if (AuthState.CurrentActor?.Name?.FirstOrDefault() is string name && !string.IsNullOrWhiteSpace(name))
            return name;
        
        if (AuthState.CurrentActor is Person person && !string.IsNullOrWhiteSpace(person.PreferredUsername))
            return person.PreferredUsername;
        
        return "User";
    }

    public void Dispose()
    {
        AuthState.AuthenticationStateChanged -= OnAuthStateChanged;
    }
}

<style>
    .home-container {
        max-width: 800px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .home-header {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--neutral-stroke-divider-rest);
    }

    .home-header h1 {
        margin: 0;
    }

    .home-header p {
        margin: 0;
        color: var(--neutral-foreground-hint);
    }

    .loading-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem 2rem;
        text-align: center;
        gap: 1rem;
    }

    .empty-state,
    .error-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem 2rem;
        text-align: center;
        gap: 1rem;
    }

    .empty-state h3,
    .error-state h3 {
        margin: 0;
    }

    .empty-state p,
    .error-state p {
        margin: 0;
        color: var(--neutral-foreground-hint);
    }
</style>

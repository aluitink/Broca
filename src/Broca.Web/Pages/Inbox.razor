@page "/inbox"
@using Broca.Web.Services
@using Broca.ActivityPub.Components
@inject AuthenticationStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Inbox - Broca</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
            <FluentLabel Typo="Typography.Subject">Authentication Required</FluentLabel>
            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Please login to view your inbox.</FluentLabel>
            <FluentButton Appearance="Appearance.Accent" OnClick="@(() => Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString("/inbox")}"))">
                Login
            </FluentButton>
        </FluentStack>
    </FluentCard>
}
else
{
    <div class="inbox-container">
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="4" Class="inbox-header">
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center">
                <FluentIcon Value="@(new Icons.Regular.Size24.Mail())" Color="Color.Accent" />
                <FluentLabel Typo="Typography.PageTitle">Inbox</FluentLabel>
            </FluentStack>
            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Activities sent to you from other actors</FluentLabel>
        </FluentStack>

        @if (_inboxUrl != null)
        {
            <ActivityFeed 
                CollectionUrl="@_inboxUrl" 
                PageSize="20"
                UseVirtualization="true"
                ShowObjects="true"
                ShowRecipients="false">
                <EmptyTemplate>
                    <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                                 Style="padding: 3rem 2rem; text-align: center;" VerticalGap="16">
                        <FluentIcon Value="@(new Icons.Regular.Size48.MailInbox())" Color="Color.Neutral" />
                        <FluentLabel Typo="Typography.Subject">Your inbox is empty</FluentLabel>
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">When other actors interact with you, their activities will appear here.</FluentLabel>
                    </FluentStack>
                </EmptyTemplate>
                <ErrorTemplate Context="error">
                    <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                                 Style="padding: 3rem 2rem; text-align: center;" VerticalGap="16">
                        <FluentIcon Value="@(new Icons.Regular.Size48.Warning())" Color="Color.Error" />
                        <FluentLabel Typo="Typography.Subject">Failed to load inbox</FluentLabel>
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@error</FluentLabel>
                        <FluentButton Appearance="Appearance.Accent" OnClick="@(() => StateHasChanged())">
                            Retry
                        </FluentButton>
                    </FluentStack>
                </ErrorTemplate>
            </ActivityFeed>
        }
        else
        {
            <FluentCard>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center">
                    <FluentIcon Value="@(new Icons.Regular.Size24.Warning())" Color="Color.Warning" />
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Unable to determine inbox URL for this actor.</FluentLabel>
                </FluentStack>
            </FluentCard>
        }
    </div>
}

@code {
    private Uri? _inboxUrl;

    protected override void OnInitialized()
    {
        // Subscribe to authentication state changes
        AuthState.AuthenticationStateChanged += OnAuthStateChanged;
        
        // Get inbox URL
        UpdateInboxUrl();
    }

    private void OnAuthStateChanged(object? sender, bool isAuthenticated)
    {
        UpdateInboxUrl();
        InvokeAsync(StateHasChanged);
    }

    private void UpdateInboxUrl()
    {
        _inboxUrl = AuthState.GetInboxUrl();
    }

    public void Dispose()
    {
        AuthState.AuthenticationStateChanged -= OnAuthStateChanged;
    }
}

<style>
    .inbox-container {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        max-width: 800px;
        margin: 0 auto;
    }

    .inbox-header {
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--neutral-stroke-divider-rest);
    }
</style>

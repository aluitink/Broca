@page "/outbox"
@using Broca.Web.Services
@using Broca.ActivityPub.Components
@inject AuthenticationStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Outbox - Broca</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
            <FluentLabel Typo="Typography.Subject">Authentication Required</FluentLabel>
            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Please login to view your outbox.</FluentLabel>
            <FluentButton Appearance="Appearance.Accent" OnClick="@(() => Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString("/outbox")}"))">
                Login
            </FluentButton>
        </FluentStack>
    </FluentCard>
}
else
{
    <div class="outbox-container">
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="4" Class="outbox-header">
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center">
                <FluentIcon Value="@(new Icons.Regular.Size24.Send())" Color="Color.Accent" />
                <FluentLabel Typo="Typography.PageTitle">Outbox</FluentLabel>
            </FluentStack>
            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Activities you have sent</FluentLabel>
        </FluentStack>

        @if (!string.IsNullOrEmpty(_postMessage))
        {
            <FluentMessageBar Intent="@_postMessageIntent" Class="post-message">
                @_postMessage
            </FluentMessageBar>
        }

        @if (_outboxUrl != null)
        {
            <ActivityFeed 
                CollectionUrl="@_outboxUrl" 
                PageSize="20"
                UseVirtualization="true"
                ShowObjects="true"
                ShowRecipients="true">
                <EmptyTemplate>
                    <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                                 Style="padding: 3rem 2rem; text-align: center;" VerticalGap="16">
                        <FluentIcon Value="@(new Icons.Regular.Size48.Send())" Color="Color.Neutral" />
                        <FluentLabel Typo="Typography.Subject">Your outbox is empty</FluentLabel>
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Activities you send will appear here.</FluentLabel>
                    </FluentStack>
                </EmptyTemplate>
                <ErrorTemplate Context="error">
                    <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                                 Style="padding: 3rem 2rem; text-align: center;" VerticalGap="16">
                        <FluentIcon Value="@(new Icons.Regular.Size48.Warning())" Color="Color.Error" />
                        <FluentLabel Typo="Typography.Subject">Failed to load outbox</FluentLabel>
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@error</FluentLabel>
                        <FluentButton Appearance="Appearance.Accent" OnClick="@(() => StateHasChanged())">
                            Retry
                        </FluentButton>
                    </FluentStack>
                </ErrorTemplate>
            </ActivityFeed>
        }
        else
        {
            <FluentCard>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center">
                    <FluentIcon Value="@(new Icons.Regular.Size24.Warning())" Color="Color.Warning" />
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Unable to determine outbox URL for this actor.</FluentLabel>
                </FluentStack>
            </FluentCard>
        }
    </div>
}

@code {
    private Uri? _outboxUrl;
    private string? _postMessage;
    private MessageIntent _postMessageIntent = MessageIntent.Success;

    protected override void OnInitialized()
    {
        AuthState.AuthenticationStateChanged += OnAuthStateChanged;
        UpdateOutboxUrl();
    }

    private void OnAuthStateChanged(object? sender, bool isAuthenticated)
    {
        UpdateOutboxUrl();
        InvokeAsync(StateHasChanged);
    }

    private void UpdateOutboxUrl()
    {
        _outboxUrl = AuthState.GetOutboxUrl();
    }

    private Task HandlePostCreated(Activity activity)
    {
        _postMessage = "Post sent successfully!";
        _postMessageIntent = MessageIntent.Success;
        StateHasChanged();
        
        // Clear message after 3 seconds
        Task.Delay(3000).ContinueWith(_ =>
        {
            _postMessage = null;
            InvokeAsync(StateHasChanged);
        });
        
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        AuthState.AuthenticationStateChanged -= OnAuthStateChanged;
    }
}

<style>
    .outbox-container {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        max-width: 800px;
        margin: 0 auto;
    }

    .outbox-header {
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--neutral-stroke-divider-rest);
    }

    .post-message {
        margin-top: 1rem;
    }
</style>

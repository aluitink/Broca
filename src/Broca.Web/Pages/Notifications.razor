@page "/notifications"
@using Broca.Web.Services
@using Broca.ActivityPub.Components
@inject AuthenticationStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Notifications - Broca</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
            <FluentLabel Typo="Typography.Subject">Authentication Required</FluentLabel>
            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Please login to view your notifications.</FluentLabel>
            <FluentButton Appearance="Appearance.Accent" OnClick="@(() => Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString("/notifications")}"))">
                Login
            </FluentButton>
        </FluentStack>
    </FluentCard>
}
else
{
    <div class="notifications-container">
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="4" Class="notifications-header">
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center">
                <FluentIcon Value="@(new Icons.Regular.Size24.Alert())" Color="Color.Accent" />
                <FluentLabel Typo="Typography.PageTitle">Notifications</FluentLabel>
            </FluentStack>
            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Activity that mentions you or interacts with your content</FluentLabel>
        </FluentStack>

        @if (_inboxUrl != null)
        {
            <NotificationFeed 
                InboxUrl="@_inboxUrl"
                Title=""
                PageSize="20"
                ShowFilters="true"
                AutoMarkAsRead="true"
                OnNotificationClick="@HandleNotificationClick">
                <LoadingTemplate>
                    <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                                 Style="padding: 2rem; text-align: center;" VerticalGap="16">
                        <FluentProgressRing />
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Loading notifications...</FluentLabel>
                    </FluentStack>
                </LoadingTemplate>
                <EmptyTemplate>
                    <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                                 Style="padding: 3rem 2rem; text-align: center;" VerticalGap="16">
                        <FluentIcon Value="@(new Icons.Regular.Size48.Alert())" Color="Color.Neutral" />
                        <FluentLabel Typo="Typography.Subject">No notifications</FluentLabel>
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">When someone interacts with your content, you'll see it here.</FluentLabel>
                    </FluentStack>
                </EmptyTemplate>
                <ErrorTemplate Context="error">
                    <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center"
                                 Style="padding: 3rem 2rem; text-align: center;" VerticalGap="16">
                        <FluentIcon Value="@(new Icons.Regular.Size48.Warning())" Color="Color.Error" />
                        <FluentLabel Typo="Typography.Subject">Failed to load notifications</FluentLabel>
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">@error</FluentLabel>
                        <FluentButton Appearance="Appearance.Accent" OnClick="@(() => StateHasChanged())">
                            Retry
                        </FluentButton>
                    </FluentStack>
                </ErrorTemplate>
            </NotificationFeed>
        }
        else
        {
            <FluentCard>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center">
                    <FluentIcon Value="@(new Icons.Regular.Size24.Warning())" Color="Color.Warning" />
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Unable to determine inbox URL for notifications.</FluentLabel>
                </FluentStack>
            </FluentCard>
        }
    </div>
}

@code {
    private Uri? _inboxUrl;

    protected override void OnInitialized()
    {
        AuthState.AuthenticationStateChanged += OnAuthStateChanged;
        UpdateInboxUrl();
    }

    private void OnAuthStateChanged(object? sender, bool isAuthenticated)
    {
        UpdateInboxUrl();
        InvokeAsync(StateHasChanged);
    }

    private void UpdateInboxUrl()
    {
        _inboxUrl = AuthState.GetInboxUrl();
    }

    private Task HandleNotificationClick(NotificationFeed.Notification notification)
    {
        // Navigate to the activity or object if applicable
        var activityObject = notification.Object;
        if (activityObject?.Id is string objectId && !string.IsNullOrEmpty(objectId))
        {
            // Could navigate to a detailed view of the activity
            // Navigation.NavigateTo($"/activity/{Uri.EscapeDataString(objectId)}");
        }
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        AuthState.AuthenticationStateChanged -= OnAuthStateChanged;
    }
}

<style>
    .notifications-container {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        max-width: 800px;
        margin: 0 auto;
    }

    .notifications-header {
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--neutral-stroke-divider-rest);
    }
</style>

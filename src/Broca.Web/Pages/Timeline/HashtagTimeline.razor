@page "/timeline/hashtag/{hashtag}"
@using Broca.Web.Services
@using Broca.ActivityPub.Components
@using Broca.ActivityPub.Core.Interfaces
@using Broca.Web.Renderers
@using static Broca.ActivityPub.Components.FeedFilter
@inject AuthenticationStateService AuthState
@inject NavigationManager Navigation
@inject IActivityPubClient Client

<PageTitle>@GetPageTitle() - Broca</PageTitle>

<div class="timeline-container">
    @if (!AuthState.IsAuthenticated)
    {
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                <FluentLabel Typo="Typography.Subject">Authentication Required</FluentLabel>
                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Please login to view hashtag timelines.</FluentLabel>
                <FluentButton Appearance="Appearance.Accent" OnClick="@(() => Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString("/timeline/hashtag/" + Hashtag)}"))">
                    Login
                </FluentButton>
            </FluentStack>
        </FluentCard>
    }
    else if (string.IsNullOrEmpty(Hashtag))
    {
        <FluentCard>
            <FluentMessageBar Intent="MessageIntent.Warning">
                No hashtag specified. Please provide a hashtag to view.
            </FluentMessageBar>
        </FluentCard>
    }
    else
    {
        <div class="timeline-header">
            <div class="header-content">
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8"
                             VerticalAlignment="VerticalAlignment.Center" Style="margin-bottom: 0.5rem;">
                    <FluentIcon Value="@(new Icons.Regular.Size24.Tag())" Color="Color.Accent" />
                    <FluentLabel Typo="Typography.PageTitle">#@Hashtag</FluentLabel>
                </FluentStack>
                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">Posts tagged with #@Hashtag</FluentLabel>
            </div>
            <div class="timeline-actions">
                <FluentButton 
                    Appearance="Appearance.Outline"
                    IconStart="@(new Icons.Regular.Size20.Filter())"
                    OnClick="@ToggleFilter">
                    @(showFilter ? "Hide" : "Show") Filters
                </FluentButton>
                <FluentButton 
                    Appearance="@(isFollowing ? Appearance.Outline : Appearance.Accent)"
                    IconStart="@(isFollowing ? new Icons.Regular.Size20.PersonDelete() : new Icons.Regular.Size20.PersonAdd())"
                    OnClick="@ToggleFollowHashtag">
                    @(isFollowing ? "Unfollow" : "Follow") Tag
                </FluentButton>
                <FluentButton 
                    Appearance="Appearance.Accent"
                    IconStart="@(new Icons.Regular.Size20.Compose())"
                    OnClick="@(() => Navigation.NavigateTo("/"))">
                    New Post
                </FluentButton>
            </div>
        </div>

        @if (_hashtagTimelineUrl != null)
        {
            <ActivityFeed 
                CollectionUrl="@_hashtagTimelineUrl"
                PageSize="20"
                UseVirtualization="true"
                ItemSize="200"
                ShowSearch="true"
                ShowFilter="@showFilter"
                FilterTemplate="@CreateFilterTemplate()"
                ShowScrollToTop="true"
                EnableAutoRefresh="true"
                AutoRefreshInterval="60"
                ShowNewPostsNotification="true"
                CssClass="hashtag-timeline-feed">
                <ActivityTemplate Context="activity">
                    <div class="activity-item">
                        <ObjectDisplay Object="@activity" />
                    </div>
                </ActivityTemplate>
            </ActivityFeed>
        }
        else
        {
            <FluentCard>
                <FluentMessageBar Intent="MessageIntent.Info">
                    Hashtag timeline is not available. This feature requires server-side support for hashtag-based collections.
                </FluentMessageBar>
            </FluentCard>
        }
    }
</div>

@code {
    [Parameter]
    public string? Hashtag { get; set; }

    private Uri? _hashtagTimelineUrl;
    private bool showFilter = false;
    private bool isFollowing = false;

    protected override void OnInitialized()
    {
        AuthState.AuthenticationStateChanged += OnAuthStateChanged;
        UpdateHashtagTimelineUrl();
    }

    protected override void OnParametersSet()
    {
        UpdateHashtagTimelineUrl();
    }

    private void OnAuthStateChanged(object? sender, bool isAuthenticated)
    {
        UpdateHashtagTimelineUrl();
        InvokeAsync(StateHasChanged);
    }

    private void UpdateHashtagTimelineUrl()
    {
        // Construct hashtag timeline URL based on current instance
        // This would typically be /api/v1/timelines/tag/{hashtag} or similar
        // For now, we'll use a placeholder - this should be configured based on server
        if (AuthState.IsAuthenticated && AuthState.CurrentActorId != null && !string.IsNullOrEmpty(Hashtag))
        {
            var baseUri = new Uri(AuthState.CurrentActorId);
            var cleanHashtag = Hashtag.TrimStart('#');
            _hashtagTimelineUrl = new Uri(baseUri, $"/api/timelines/tag/{Uri.EscapeDataString(cleanHashtag)}");
        }
        else
        {
            _hashtagTimelineUrl = null;
        }
    }

    private void ToggleFilter()
    {
        showFilter = !showFilter;
    }

    private async Task ToggleFollowHashtag()
    {
        // TODO: Implement hashtag following/unfollowing
        // This would require server-side support for following hashtags
        isFollowing = !isFollowing;
        await Task.CompletedTask;
    }

    private RenderFragment CreateFilterTemplate()
    {
        return builder =>
        {
            builder.OpenComponent<FeedFilter>(0);
            builder.AddAttribute(1, nameof(FeedFilter.FilterTemplate), FluentFeedFilterRenderer.Template);
            builder.AddAttribute(2, nameof(FeedFilter.ShowActivityTypeFilter), true);
            builder.AddAttribute(3, nameof(FeedFilter.ShowContentTypeFilter), true);
            builder.AddAttribute(4, nameof(FeedFilter.ShowActorFilter), true);
            builder.AddAttribute(5, nameof(FeedFilter.ShowDateRangeFilter), true);
            builder.CloseComponent();
        };
    }

    private string GetPageTitle()
    {
        return string.IsNullOrEmpty(Hashtag) ? "Hashtag Timeline" : $"#{Hashtag}";
    }

    public void Dispose()
    {
        AuthState.AuthenticationStateChanged -= OnAuthStateChanged;
    }
}

<style>
    .timeline-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .timeline-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--neutral-stroke-divider-rest);
    }

    .header-content {
        flex: 1;
    }

    .timeline-actions {
        display: flex;
        gap: 0.75rem;
    }

    .activity-item {
        padding: 1rem;
        border-bottom: 1px solid var(--neutral-stroke-divider-rest);
    }

    .activity-item:last-child {
        border-bottom: none;
    }

    @@media (max-width: 768px) {
        .timeline-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }

        .timeline-actions {
            width: 100%;
            flex-direction: column;
        }
    }
</style>

@page "/timeline/federated"
@using Broca.Web.Services
@using Broca.ActivityPub.Components
@using Broca.ActivityPub.Core.Interfaces
@using Broca.Web.Renderers
@using static Broca.ActivityPub.Components.FeedFilter
@inject AuthenticationStateService AuthState
@inject NavigationManager Navigation
@inject IActivityPubClient Client

<PageTitle>Federated Timeline - Broca</PageTitle>

<div class="timeline-container">
    @if (!AuthState.IsAuthenticated)
    {
        <FluentCard>
            <h2>Authentication Required</h2>
            <p>Please login to view the federated timeline.</p>
            <FluentButton Appearance="Appearance.Accent" OnClick="@(() => Navigation.NavigateTo("/login?returnUrl=/timeline/federated"))">
                Login
            </FluentButton>
        </FluentCard>
    }
    else
    {
        <div class="timeline-header">
            <div class="header-content">
                <div class="header-title">
                    <FluentIcon Value="@(new Icons.Regular.Size24.Globe())" Color="Color.Accent" />
                    <h1>Federated Timeline</h1>
                </div>
                <p class="header-subtitle">Public posts from across the fediverse</p>
            </div>
            <div class="timeline-actions">
                <FluentButton 
                    Appearance="Appearance.Outline"
                    IconStart="@(new Icons.Regular.Size20.Filter())"
                    OnClick="@ToggleFilter">
                    @(showFilter ? "Hide" : "Show") Filters
                </FluentButton>
                <FluentButton 
                    Appearance="Appearance.Accent"
                    IconStart="@(new Icons.Regular.Size20.Compose())"
                    OnClick="@(() => Navigation.NavigateTo("/"))">
                    New Post
                </FluentButton>
            </div>
        </div>

        @if (_federatedTimelineUrl != null)
        {
            <ActivityFeed 
                CollectionUrl="@_federatedTimelineUrl"
                PageSize="20"
                UseVirtualization="true"
                ItemSize="200"
                ShowSearch="true"
                ShowFilter="@showFilter"
                FilterTemplate="@CreateFilterTemplate()"
                ShowScrollToTop="true"
                EnableAutoRefresh="true"
                AutoRefreshInterval="60"
                ShowNewPostsNotification="true"
                CssClass="federated-timeline-feed">
                <ActivityTemplate Context="activity">
                    <div class="activity-item">
                        <ObjectDisplay Object="@activity" />
                    </div>
                </ActivityTemplate>
            </ActivityFeed>
        }
        else
        {
            <FluentCard>
                <FluentMessageBar Intent="MessageIntent.Info">
                    Federated timeline is not available. This feature requires server-side support for a public federated timeline collection.
                </FluentMessageBar>
            </FluentCard>
        }
    }
</div>

@code {
    private Uri? _federatedTimelineUrl;
    private bool showFilter = false;

    protected override void OnInitialized()
    {
        AuthState.AuthenticationStateChanged += OnAuthStateChanged;
        UpdateFederatedTimelineUrl();
    }

    private void OnAuthStateChanged(object? sender, bool isAuthenticated)
    {
        UpdateFederatedTimelineUrl();
        InvokeAsync(StateHasChanged);
    }

    private void UpdateFederatedTimelineUrl()
    {
        // Construct federated timeline URL based on current instance
        // This would typically be /api/v1/timelines/public or similar
        // For now, we'll use a placeholder - this should be configured based on server
        if (AuthState.IsAuthenticated && AuthState.CurrentActorId != null)
        {
            var baseUri = new Uri(AuthState.CurrentActorId);
            _federatedTimelineUrl = new Uri(baseUri, "/api/timelines/public");
        }
    }

    private void ToggleFilter()
    {
        showFilter = !showFilter;
    }

    private RenderFragment CreateFilterTemplate()
    {
        return builder =>
        {
            builder.OpenComponent<FeedFilter>(0);
            builder.AddAttribute(1, nameof(FeedFilter.FilterTemplate), FluentFeedFilterRenderer.Template);
            builder.AddAttribute(2, nameof(FeedFilter.ShowActivityTypeFilter), true);
            builder.AddAttribute(3, nameof(FeedFilter.ShowContentTypeFilter), true);
            builder.AddAttribute(4, nameof(FeedFilter.ShowActorFilter), true);
            builder.AddAttribute(5, nameof(FeedFilter.ShowDateRangeFilter), true);
            builder.CloseComponent();
        };
    }

    public void Dispose()
    {
        AuthState.AuthenticationStateChanged -= OnAuthStateChanged;
    }
}

<style>
    .timeline-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .timeline-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--neutral-stroke-divider-rest);
    }

    .header-content {
        flex: 1;
    }

    .header-title {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.5rem;
    }

    .header-title h1 {
        margin: 0;
        font-size: 1.75rem;
    }

    .header-subtitle {
        margin: 0;
        color: var(--neutral-foreground-hint);
        font-size: 0.875rem;
    }

    .timeline-actions {
        display: flex;
        gap: 0.75rem;
    }

    .activity-item {
        padding: 1rem;
        border-bottom: 1px solid var(--neutral-stroke-divider-rest);
    }

    .activity-item:last-child {
        border-bottom: none;
    }

    @@media (max-width: 768px) {
        .timeline-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }

        .timeline-actions {
            width: 100%;
            flex-direction: column;
        }
    }
</style>

@using KristofferStrube.ActivityStreams
@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using Broca.ActivityPub.Components
@using Broca.ActivityPub.Components.Services
@using Broca.ActivityPub.Core.Interfaces
@inject ActorResolutionService ActorResolver
@inject NavigationManager Navigation
@inject IActivityPubClient? ActivityPubClient
@inherits ComponentBase

<FluentCard Class="@($"fluent-note-card {CssClass}")">
    @if (Note != null)
    {
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
            @* Header with actor and timestamp *@
            <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" class="note-header">
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12" VerticalAlignment="VerticalAlignment.Center" Style="flex: 1;">
                    @if (ShowActor && Note.AttributedTo?.Any() == true)
                    {
                        <div class="actor-info-clickable" @onclick="NavigateToActor" style="cursor: pointer;">
                            <FluentPersona Name="@GetActorDisplay()"
                                           Image="@GetActorImageUrl()"
                                           ImageSize="32px"
                                           TextPosition="@TextPosition.End">
                                @if (!string.IsNullOrEmpty(GetActorUsername()))
                                {
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">
                                        @@@GetActorUsername()
                                    </FluentLabel>
                                }
                            </FluentPersona>
                        </div>
                    }
                    
                    @if (Note.Published.HasValue)
                    {
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral" class="note-timestamp">
                            <time datetime="@Note.Published.Value.ToString("o")" title="@Note.Published.Value.ToString("f")">
                                @FormatDateTime(Note.Published.Value)
                            </time>
                        </FluentLabel>
                    }
                </FluentStack>
                
                @if (ShowMenu)
                {
                    <ObjectMenu Object="@Note"
                               ObjectId="@Note.Id"
                               ActorId="@(actorInfo?.Id ?? (Note.AttributedTo?.FirstOrDefault() as IObject)?.Id)" />
                }
            </FluentStack>

            @* Title *@
            @if (Note.Name?.Any() == true)
            {
                <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold" class="note-title">
                    @Note.Name.First()
                </FluentLabel>
            }

            @* In Reply To *@
            @if (Note.InReplyTo?.Any() == true)
            {
                <div class="note-in-reply-to">
                    @if (isLoadingReplyTo)
                    {
                        <FluentProgressRing Style="width: 20px; height: 20px;" />
                    }
                    else if (inReplyToObject is Note replyNote)
                    {
                        @if (replyNote.AttributedTo?.Any() == true)
                        {
                            <FluentPersona Name="@GetReplyActorDisplay(replyNote)"
                                           Image="@GetReplyActorImageUrl(replyNote)"
                                           ImageSize="24px"
                                           TextPosition="TextPosition.End"
                                           class="reply-to-actor" />
                        }
                        @if (replyNote.Content?.Any() == true)
                        {
                            <div class="note-content reply-to-content">
                                @((MarkupString)(replyNote.Content.First() ?? string.Empty))
                            </div>
                        }
                        else if (replyNote.Name?.Any() == true)
                        {
                            <div class="reply-to-content">@replyNote.Name.First()</div>
                        }
                    }
                    else if (inReplyToObject is KristofferStrube.ActivityStreams.Object replyObj)
                    {
                        @if (replyObj.Content?.Any() == true)
                        {
                            <div class="note-content reply-to-content">
                                @((MarkupString)(replyObj.Content.First() ?? string.Empty))
                            </div>
                        }
                        else if (replyObj.Name?.Any() == true)
                        {
                            <div class="reply-to-content">@replyObj.Name.First()</div>
                        }
                    }
                    else
                    {
                        var replyToRef = Note.InReplyTo.First();
                        var replyToUrl = replyToRef is ILink l ? l.Href?.ToString() : (replyToRef as IObject)?.Id;
                        if (!string.IsNullOrEmpty(replyToUrl))
                        {
                            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="4" VerticalAlignment="VerticalAlignment.Center">
                                <FluentIcon Value="@(new Icons.Regular.Size16.ArrowReply())" Color="Color.Neutral" />
                                <FluentAnchor Href="@replyToUrl" Target="_blank" Appearance="Appearance.Hypertext">@replyToUrl</FluentAnchor>
                            </FluentStack>
                        }
                    }
                </div>
            }

            @* Content *@
            @if (Note.Content?.Any() == true)
            {
                <div class="note-content">
                    @((MarkupString)(Note.Content.First() ?? string.Empty))
                </div>
            }

            @* Attachments *@
            @if (Note.Attachment?.Any() == true)
            {
                <FluentStack Orientation="Orientation.Horizontal" Wrap="true" class="note-attachments">
                    @foreach (var attachment in Note.Attachment)
                    {
                        <div class="attachment-item">
                            @RenderAttachment(attachment)
                        </div>
                    }
                </FluentStack>
            }

            @* Interaction Bar *@
            @if (ShowActions && !string.IsNullOrEmpty(Note.Id))
            {
                <FluentDivider Style="margin: 0;" />
                <InteractionBar ObjectId="@Note.Id"
                                Object="@Note"
                                ShowReply="true"
                                ShowBoost="true"
                                ShowLike="true"
                                ShowBookmark="false"
                                ShowShare="false"
                                ReplyCount="@GetReplyCount()"
                                OnReplyClick="@HandleReplyButtonClick"
                                BarTemplate="FluentInteractionBarRenderer.Template" />

                @if (showReplies && !string.IsNullOrEmpty(GetRepliesUrl()))
                {
                    <FluentDivider Style="margin: 0;" />
                    <ReplyThread RepliesCollectionUrl="@GetRepliesUrl()"
                                 ShowEmptyState="false"
                                 CssClass="note-replies" />
                }
            }

            @if (AdditionalContent != null)
            {
                @AdditionalContent(Note)
            }
        </FluentStack>
    }
</FluentCard>

@code {
    private ActorInfo? actorInfo;
    private bool showReplies;
    private object? inReplyToObject;
    private bool isLoadingReplyTo;

    /// <summary>
    /// Gets or sets the Note object to render.
    /// </summary>
    [Parameter]
    public Note? Note { get; set; }

    /// <summary>
    /// Gets or sets whether to show the actor attribution.
    /// </summary>
    [Parameter]
    public bool ShowActor { get; set; } = true;

    /// <summary>
    /// Gets or sets whether to show action buttons.
    /// </summary>
    [Parameter]
    public bool ShowActions { get; set; } = true;

    /// <summary>
    /// Gets or sets whether to show the menu button.
    /// </summary>
    [Parameter]
    public bool ShowMenu { get; set; } = true;

    /// <summary>
    /// Gets or sets additional CSS classes.
    /// </summary>
    [Parameter]
    public string? CssClass { get; set; }

    /// <summary>
    /// Gets or sets additional content to render.
    /// </summary>
    [Parameter]
    public RenderFragment<Note>? AdditionalContent { get; set; }

    /// <summary>
    /// Event callback for reply action.
    /// </summary>
    [Parameter]
    public EventCallback<Note> OnReply { get; set; }

    /// <summary>
    /// Event callback for boost action.
    /// </summary>
    [Parameter]
    public EventCallback<Note> OnBoost { get; set; }

    /// <summary>
    /// Event callback for like action.
    /// </summary>
    [Parameter]
    public EventCallback<Note> OnLike { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (Note?.AttributedTo?.Any() == true)
        {
            actorInfo = await ActorResolver.ResolveActorAsync(Note.AttributedTo.First());
        }
        await LoadInReplyTo();
    }

    private async Task LoadInReplyTo()
    {
        inReplyToObject = null;
        if (ActivityPubClient == null || Note?.InReplyTo?.Any() != true)
            return;

        var replyToRef = Note.InReplyTo.First();

        if (replyToRef is IObject inlineObj && replyToRef is not ILink && HasDisplayableContent(inlineObj))
        {
            inReplyToObject = inlineObj;
            return;
        }

        Uri? urlToFetch = null;
        if (replyToRef is ILink link && link.Href != null)
            urlToFetch = link.Href;
        else if (replyToRef is IObject refObj && !string.IsNullOrEmpty(refObj.Id))
            Uri.TryCreate(refObj.Id, UriKind.Absolute, out urlToFetch);
        else
        {
            var urlString = replyToRef?.ToString();
            if (!string.IsNullOrEmpty(urlString))
                Uri.TryCreate(urlString, UriKind.Absolute, out urlToFetch);
        }

        if (urlToFetch != null)
        {
            try
            {
                isLoadingReplyTo = true;
                StateHasChanged();
                var fetched = await ActivityPubClient.GetAsync<KristofferStrube.ActivityStreams.Object>(urlToFetch, useCache: true);
                if (fetched != null)
                    inReplyToObject = fetched;
            }
            catch { }
            finally
            {
                isLoadingReplyTo = false;
                StateHasChanged();
            }
        }
    }

    private static bool HasDisplayableContent(IObject obj)
    {
        if (obj is KristofferStrube.ActivityStreams.Object o)
            return o.Content?.Any() == true || o.Name?.Any() == true || o.Summary?.Any() == true;
        return false;
    }

    private string GetReplyActorDisplay(Note note)
    {
        var actorRef = note.AttributedTo?.FirstOrDefault();
        if (actorRef is Actor actor && actor.Name?.Any() == true)
            return actor.Name.First();
        if (actorRef is KristofferStrube.ActivityStreams.Object obj)
        {
            if (obj.Name?.Any() == true) return obj.Name.First();
            if (!string.IsNullOrEmpty(obj.Id)) return obj.Id;
        }
        if (actorRef is ILink link && link.Href != null)
            return link.Href.ToString();
        return "Unknown";
    }

    private string GetReplyActorImageUrl(Note note)
    {
        var actorRef = note.AttributedTo?.FirstOrDefault();
        if (actorRef is Person person && person.Icon?.Any() == true)
        {
            var icon = person.Icon.First();
            if (icon is Image img && img.Url?.Any() == true)
            {
                var url = img.Url.First();
                if (url is ILink link && link.Href != null)
                    return link.Href.ToString();
            }
        }
        return string.Empty;
    }

    private int GetReplyCount()
    {
        if (Note?.Replies is Collection collection)
            return (int)(collection.TotalItems ?? 0);
        return 0;
    }

    private string? GetRepliesUrl()
    {
        return (Note?.Replies as Collection)?.Id;
    }

    private Task HandleReplyButtonClick()
    {
        if (GetRepliesUrl() != null)
            showReplies = !showReplies;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void NavigateToActor()
    {
        if (actorInfo?.Id != null)
        {
            var encodedActorId = Uri.EscapeDataString(actorInfo.Id);
            Navigation.NavigateTo($"/actor?id={encodedActorId}");
        }
    }

    private string GetActorDisplay()
    {
        if (actorInfo != null)
            return actorInfo.Name;

        var actorLink = Note?.AttributedTo?.FirstOrDefault();
        if (actorLink == null) return "Unknown";
        
        // Try to get Name from Actor
        if (actorLink is Actor actor && actor.Name?.Any() == true)
            return actor.Name.First();
        
        // Try to get Name from any Object
        if (actorLink is KristofferStrube.ActivityStreams.Object obj)
        {
            if (obj.Name?.Any() == true)
                return obj.Name.First();
            if (!string.IsNullOrEmpty(obj.Id))
                return obj.Id;
        }
        
        // Try to get Href from Link
        if (actorLink is Link link && link.Href != null)
            return link.Href.ToString();
        
        return "Unknown";
    }

    private string GetActorImageUrl()
    {
        if (actorInfo?.IconUrl != null)
            return actorInfo.IconUrl;

        var actorLink = Note?.AttributedTo?.FirstOrDefault();
        if (actorLink == null) return string.Empty;
        
        if (actorLink is Person person && person.Icon?.Any() == true)
        {
            var icon = person.Icon.First();
            if (icon is Image img && img.Url?.Any() == true)
            {
                var url = img.Url.First();
                if (url is Link link && link.Href != null)
                    return link.Href.ToString();
            }
        }
        
        return string.Empty;
    }

    private string GetActorUsername()
    {
        if (actorInfo != null)
            return actorInfo.PreferredUsername;

        var actorLink = Note?.AttributedTo?.FirstOrDefault();
        if (actorLink == null) return string.Empty;
        
        if (actorLink is Person person && !string.IsNullOrEmpty(person.PreferredUsername))
            return person.PreferredUsername;
        
        return string.Empty;
    }

    private RenderFragment RenderAttachment(IObjectOrLink attachment)
    {
        return builder =>
        {
            if (attachment is Image img)
            {
                builder.OpenElement(0, "img");
                builder.AddAttribute(1, "src", GetImageUrl(img));
                builder.AddAttribute(2, "alt", GetImageAlt(img));
                builder.AddAttribute(3, "loading", "lazy");
                builder.AddAttribute(4, "style", "max-width: 100%; border-radius: 4px;");
                builder.CloseElement();
            }
            else if (attachment is Document doc)
            {
                builder.OpenComponent<FluentButton>(0);
                builder.AddAttribute(1, "Appearance", Appearance.Lightweight);
                builder.AddAttribute(2, "IconStart", new Icons.Regular.Size16.Document());
                builder.AddContent(3, GetDocumentName(doc));
                builder.CloseComponent();
            }
        };
    }

    private string GetImageUrl(Image img)
    {
        var url = img.Url?.FirstOrDefault();
        if (url is Link link && link.Href != null)
            return link.Href.ToString();
        return url?.ToString() ?? string.Empty;
    }

    private string GetImageAlt(Image img)
    {
        return img.Name?.FirstOrDefault() ?? "Image attachment";
    }

    private string GetDocumentName(Document doc)
    {
        return doc.Name?.FirstOrDefault() ?? "Document";
    }

    private string FormatDateTime(DateTime dateTime)
    {
        var timeSpan = DateTime.UtcNow - dateTime.ToUniversalTime();
        
        if (timeSpan.TotalMinutes < 1)
            return "just now";
        if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes}m ago";
        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours}h ago";
        if (timeSpan.TotalDays < 7)
            return $"{(int)timeSpan.TotalDays}d ago";
        
        return dateTime.ToString("MMM d, yyyy");
    }
}

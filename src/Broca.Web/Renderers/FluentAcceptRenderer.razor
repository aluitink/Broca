@using KristofferStrube.ActivityStreams
@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using Broca.ActivityPub.Components
@using Broca.ActivityPub.Components.Services
@inject ActorResolutionService ActorResolver
@inject NavigationManager Navigation
@inherits ComponentBase

<FluentCard Class="@($"fluent-accept-card {CssClass}")">
    @if (Accept != null)
    {
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
            <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" class="accept-header">
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center">
                    @if (Accept.Actor?.Any() == true)
                    {
                        <div class="actor-info-clickable" @onclick="NavigateToActor" style="cursor: pointer;">
                            <FluentPersona Name="@GetActorDisplay()"
                                           Image="@GetActorImageUrl()"
                                           ImageSize="32px"
                                           TextPosition="@TextPosition.End">
                                @if (!string.IsNullOrEmpty(GetActorHandle()))
                                {
                                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral">
                                        @GetActorHandle()
                                    </FluentLabel>
                                }
                            </FluentPersona>
                        </div>
                    }

                    <FluentBadge Appearance="Appearance.Accent">
                        ✅ Accepted your follow
                    </FluentBadge>
                </FluentStack>

                @if (Accept.Published.HasValue)
                {
                    <FluentLabel Typo="Typography.Body" Color="Color.Neutral" class="accept-timestamp">
                        <time datetime="@Accept.Published.Value.ToString("o")" title="@Accept.Published.Value.ToString("f")">
                            @FormatDateTime(Accept.Published.Value)
                        </time>
                    </FluentLabel>
                }
            </FluentStack>

            @if (Accept.Object?.Any() == true)
            {
                <FluentDivider Style="margin: 0;" />
                <div class="accept-objects">
                    @foreach (var obj in Accept.Object)
                    {
                        @if (obj is Follow follow)
                        {
                            <FluentFollowRenderer Follow="@follow" IsSubActivity="true" />
                        }
                        else
                        {
                            <ObjectDisplay Object="@obj" />
                        }
                    }
                </div>
            }
        </FluentStack>
    }
</FluentCard>

@code {
    private ActorInfo? actorInfo;

    [Parameter]
    public Accept? Accept { get; set; }

    [Parameter]
    public string? CssClass { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await LoadActorInfo();
    }

    private async Task LoadActorInfo()
    {
        if (Accept?.Actor?.Any() != true)
            return;

        var actorRef = Accept.Actor.First();
        string? actorId = null;

        if (actorRef is IObject actorObj && !string.IsNullOrEmpty(actorObj.Id))
            actorId = actorObj.Id;
        else if (actorRef is ILink link && link.Href != null)
            actorId = link.Href.ToString();

        if (!string.IsNullOrEmpty(actorId))
        {
            try
            {
                actorInfo = await ActorResolver.ResolveActorAsync(new Link { Href = new Uri(actorId) });
            }
            catch
            {
                // Actor resolution failure is non-fatal; fall back to raw values
            }
        }
    }

    private string GetActorId()
    {
        var actorRef = Accept?.Actor?.FirstOrDefault();
        if (actorRef == null) return string.Empty;
        if (actorInfo != null) return actorInfo.Id;
        if (actorRef is IObject obj && !string.IsNullOrEmpty(obj.Id)) return obj.Id;
        if (actorRef is ILink link && link.Href != null) return link.Href.ToString();
        return string.Empty;
    }

    private string GetActorDisplay()
    {
        if (actorInfo != null) return actorInfo.Name;

        var actorRef = Accept?.Actor?.FirstOrDefault();
        if (actorRef == null) return "Unknown";
        if (actorRef is KristofferStrube.ActivityStreams.Object obj && obj.Name?.Any() == true)
            return obj.Name.First();
        if (actorRef is ILink link && link.Href != null)
            return link.Href.ToString();
        return "Unknown";
    }

    private string GetActorHandle()
    {
        if (actorInfo != null) return actorInfo.Handle;
        return string.Empty;
    }

    private string GetActorImageUrl()
    {
        if (actorInfo?.IconUrl != null) return actorInfo.IconUrl;
        return string.Empty;
    }

    private void NavigateToActor()
    {
        var id = GetActorId();
        if (!string.IsNullOrEmpty(id))
            Navigation.NavigateTo($"/actor?id={Uri.EscapeDataString(id)}");
    }

    private string FormatDateTime(DateTime dateTime)
    {
        var timeSpan = DateTime.UtcNow - dateTime.ToUniversalTime();

        if (timeSpan.TotalMinutes < 1) return "just now";
        if (timeSpan.TotalMinutes < 60) return $"{(int)timeSpan.TotalMinutes}m ago";
        if (timeSpan.TotalHours < 24) return $"{(int)timeSpan.TotalHours}h ago";
        if (timeSpan.TotalDays < 7) return $"{(int)timeSpan.TotalDays}d ago";

        return dateTime.ToString("MMM d, yyyy");
    }
}

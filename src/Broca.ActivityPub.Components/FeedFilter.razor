@using KristofferStrube.ActivityStreams
@using Broca.ActivityPub.Core.Interfaces

<div class="activitypub-feed-filter @CssClass">
    @if (FilterTemplate != null)
    {
        @FilterTemplate(new FeedFilterContext(this))
    }
    else
    {
        <div class="filter-container">
            @if (ShowActivityTypeFilter)
            {
                <div class="filter-group">
                    <label class="filter-label">Activity Type</label>
                    <div class="filter-options">
                        @foreach (var type in ActivityTypes)
                        {
                            <label class="filter-option">
                                <input type="checkbox" 
                                       checked="@IsActivityTypeSelected(type)"
                                       @onchange="@(e => ToggleActivityType(type, (bool)(e.Value ?? false)))" />
                                <span>@type</span>
                            </label>
                        }
                    </div>
                </div>
            }

            @if (ShowContentTypeFilter)
            {
                <div class="filter-group">
                    <label class="filter-label">Content Type</label>
                    <div class="filter-options">
                        @foreach (var type in ContentTypes)
                        {
                            <label class="filter-option">
                                <input type="checkbox" 
                                       checked="@IsContentTypeSelected(type)"
                                       @onchange="@(e => ToggleContentType(type, (bool)(e.Value ?? false)))" />
                                <span>@type</span>
                            </label>
                        }
                    </div>
                </div>
            }

            @if (ShowActorFilter)
            {
                <div class="filter-group">
                    <label class="filter-label filter-label-actor">Actor</label>
                    <div class="filter-actor-input">
                        <input type="text" 
                               class="actor-filter-textbox"
                               placeholder="Filter by actor ID or name..."
                               value="@ActorFilter"
                               @oninput="@OnActorFilterChanged" />
                        @if (!string.IsNullOrEmpty(ActorFilter))
                        {
                            <button class="clear-actor-button" @onclick="ClearActorFilter" title="Clear actor filter">
                                ✕
                            </button>
                        }
                    </div>
                </div>
            }

            @if (ShowDateRangeFilter)
            {
                <div class="filter-group">
                    <label class="filter-label">Date Range</label>
                    <div class="filter-date-inputs">
                        <div class="date-input-group">
                            <label class="date-label">From</label>
                            <input type="date" 
                                   class="date-input"
                                   value="@(StartDate?.ToString("yyyy-MM-dd"))"
                                   @onchange="@OnStartDateChanged" />
                        </div>
                        <div class="date-input-group">
                            <label class="date-label">To</label>
                            <input type="date" 
                                   class="date-input"
                                   value="@(EndDate?.ToString("yyyy-MM-dd"))"
                                   @onchange="@OnEndDateChanged" />
                        </div>
                    </div>
                </div>
            }

            <div class="filter-actions">
                <button class="apply-filter-button" @onclick="ApplyFilter">
                    Apply Filters
                </button>
                <button class="reset-filter-button" @onclick="ResetFilter">
                    Reset
                </button>
            </div>
        </div>
    }
</div>

@code {
    private HashSet<string> selectedActivityTypes = new();
    private HashSet<string> selectedContentTypes = new();

    [Parameter]
    public string? CssClass { get; set; }

    [Parameter]
    public bool ShowActivityTypeFilter { get; set; } = true;

    [Parameter]
    public bool ShowContentTypeFilter { get; set; } = true;

    [Parameter]
    public bool ShowActorFilter { get; set; } = true;

    [Parameter]
    public bool ShowDateRangeFilter { get; set; } = true;

    [Parameter]
    public IEnumerable<string> ActivityTypes { get; set; } = new[]
    {
        "Create", "Update", "Delete", "Follow", "Accept", "Reject",
        "Add", "Remove", "Like", "Announce", "Undo", "Block"
    };

    [Parameter]
    public IEnumerable<string> ContentTypes { get; set; } = new[]
    {
        "Note", "Article", "Image", "Video", "Audio", "Document",
        "Event", "Place", "Question"
    };

    [Parameter]
    public string? ActorFilter { get; set; }

    [Parameter]
    public EventCallback<string?> ActorFilterChanged { get; set; }

    [Parameter]
    public DateTime? StartDate { get; set; }

    [Parameter]
    public EventCallback<DateTime?> StartDateChanged { get; set; }

    [Parameter]
    public DateTime? EndDate { get; set; }

    [Parameter]
    public EventCallback<DateTime?> EndDateChanged { get; set; }

    [Parameter]
    public EventCallback<FeedFilterCriteria> OnFilterApplied { get; set; }

    [Parameter]
    public EventCallback OnFilterReset { get; set; }

    [Parameter]
    public RenderFragment<FeedFilterContext>? FilterTemplate { get; set; }

    protected override void OnInitialized()
    {
        // Select all types by default
        selectedActivityTypes = new HashSet<string>(ActivityTypes);
        selectedContentTypes = new HashSet<string>(ContentTypes);
    }

    public bool IsActivityTypeSelected(string type) => selectedActivityTypes.Contains(type);

    public bool IsContentTypeSelected(string type) => selectedContentTypes.Contains(type);

    public void ToggleActivityType(string type, bool isChecked)
    {
        if (isChecked)
        {
            selectedActivityTypes.Add(type);
        }
        else
        {
            selectedActivityTypes.Remove(type);
        }
    }

    public void ToggleContentType(string type, bool isChecked)
    {
        if (isChecked)
        {
            selectedContentTypes.Add(type);
        }
        else
        {
            selectedContentTypes.Remove(type);
        }
    }

    public async Task OnActorFilterChanged(ChangeEventArgs e)
    {
        ActorFilter = e.Value?.ToString();
        if (ActorFilterChanged.HasDelegate)
        {
            await ActorFilterChanged.InvokeAsync(ActorFilter);
        }
    }

    public async Task ClearActorFilter()
    {
        ActorFilter = null;
        if (ActorFilterChanged.HasDelegate)
        {
            await ActorFilterChanged.InvokeAsync(ActorFilter);
        }
    }

    public async Task OnStartDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            StartDate = date;
        }
        else
        {
            StartDate = null;
        }

        if (StartDateChanged.HasDelegate)
        {
            await StartDateChanged.InvokeAsync(StartDate);
        }
    }

    public async Task OnEndDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            EndDate = date;
        }
        else
        {
            EndDate = null;
        }

        if (EndDateChanged.HasDelegate)
        {
            await EndDateChanged.InvokeAsync(EndDate);
        }
    }

    public async Task ApplyFilter()
    {
        var criteria = new FeedFilterCriteria
        {
            ActivityTypes = selectedActivityTypes.Any() ? selectedActivityTypes.ToList() : null,
            ContentTypes = selectedContentTypes.Any() ? selectedContentTypes.ToList() : null,
            ActorFilter = ActorFilter,
            StartDate = StartDate,
            EndDate = EndDate
        };

        if (OnFilterApplied.HasDelegate)
        {
            await OnFilterApplied.InvokeAsync(criteria);
        }
    }

    public async Task ResetFilter()
    {
        selectedActivityTypes = new HashSet<string>(ActivityTypes);
        selectedContentTypes = new HashSet<string>(ContentTypes);
        ActorFilter = null;
        StartDate = null;
        EndDate = null;

        if (OnFilterReset.HasDelegate)
        {
            await OnFilterReset.InvokeAsync();
        }
    }

    public class FeedFilterContext
    {
        public FeedFilter Filter { get; }

        public FeedFilterContext(FeedFilter filter)
        {
            Filter = filter;
        }
    }

    public class FeedFilterCriteria
    {
        public List<string>? ActivityTypes { get; set; }
        public List<string>? ContentTypes { get; set; }
        public string? ActorFilter { get; set; }
        public DateTime? StartDate { get; set; }
        public DateTime? EndDate { get; set; }

        public bool ShouldFilterActivity(Activity activity)
        {
            if (ActivityTypes != null && ActivityTypes.Any())
            {
                var activityType = activity.Type?.FirstOrDefault();
                if (activityType == null || !ActivityTypes.Contains(activityType))
                {
                    return false;
                }
            }

            if (ContentTypes != null && ContentTypes.Any() && activity.Object != null)
            {
                var objRef = activity.Object.FirstOrDefault();
                if (objRef is KristofferStrube.ActivityStreams.Object obj)
                {
                    var objType = obj.Type?.FirstOrDefault();
                    if (objType == null || !ContentTypes.Contains(objType))
                    {
                        return false;
                    }
                }
            }

            if (!string.IsNullOrEmpty(ActorFilter) && activity.Actor != null)
            {
                var actorRef = activity.Actor.FirstOrDefault();
                var actorId = actorRef switch
                {
                    ILink link => link.Href?.ToString(),
                    Actor actor => actor.Id ?? actor.PreferredUsername,
                    _ => null
                };

                if (string.IsNullOrEmpty(actorId) || 
                    !actorId.Contains(ActorFilter, StringComparison.OrdinalIgnoreCase))
                {
                    return false;
                }
            }

            if (StartDate.HasValue && activity.Published.HasValue)
            {
                if (activity.Published.Value < new DateTimeOffset(StartDate.Value))
                {
                    return false;
                }
            }

            if (EndDate.HasValue && activity.Published.HasValue)
            {
                if (activity.Published.Value > new DateTimeOffset(EndDate.Value.AddDays(1)))
                {
                    return false;
                }
            }

            return true;
        }
    }
}

<style>
    .activitypub-feed-filter {
        padding: 1rem;
        background: var(--neutral-layer-1, #f9f9f9);
        border: 1px solid var(--neutral-stroke-1, #e0e0e0);
        border-radius: 4px;
        margin-bottom: 1rem;
    }

    .filter-container {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .filter-label {
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--neutral-foreground-1, #242424);
    }

    .filter-options {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .filter-option {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        cursor: pointer;
        font-size: 0.875rem;
        color: var(--neutral-foreground-2, #424242);
    }

    .filter-option input[type="checkbox"] {
        cursor: pointer;
    }

    .filter-actor-input {
        position: relative;
        display: flex;
        align-items: center;
    }

    .actor-filter-textbox {
        flex: 1;
        padding: 0.5rem;
        border: 1px solid var(--neutral-stroke-1, #d0d0d0);
        border-radius: 4px;
        font-size: 0.875rem;
    }

    .clear-actor-button {
        position: absolute;
        right: 0.5rem;
        background: transparent;
        border: none;
        cursor: pointer;
        font-size: 1rem;
        color: var(--neutral-foreground-3, #707070);
        padding: 0.25rem;
    }

    .clear-actor-button:hover {
        color: var(--neutral-foreground-1, #242424);
    }

    .filter-date-inputs {
        display: flex;
        gap: 1rem;
    }

    .date-input-group {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        flex: 1;
    }

    .date-label {
        font-size: 0.75rem;
        color: var(--neutral-foreground-3, #707070);
    }

    .date-input {
        padding: 0.5rem;
        border: 1px solid var(--neutral-stroke-1, #d0d0d0);
        border-radius: 4px;
        font-size: 0.875rem;
    }

    .filter-actions {
        display: flex;
        gap: 0.5rem;
        margin-top: 0.5rem;
    }

    .apply-filter-button,
    .reset-filter-button {
        padding: 0.5rem 1rem;
        border-radius: 4px;
        font-size: 0.875rem;
        cursor: pointer;
        border: none;
    }

    .apply-filter-button {
        background: var(--accent-fill-rest, #0078d4);
        color: white;
    }

    .apply-filter-button:hover {
        background: var(--accent-fill-hover, #106ebe);
    }

    .reset-filter-button {
        background: var(--neutral-fill-rest, #e0e0e0);
        color: var(--neutral-foreground-1, #242424);
    }

    .reset-filter-button:hover {
        background: var(--neutral-fill-hover, #d0d0d0);
    }
</style>

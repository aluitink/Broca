@using Broca.ActivityPub.Core.Interfaces
@using KristofferStrube.ActivityStreams
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using Microsoft.JSInterop
@typeparam TItem
@inject IActivityPubClient Client
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="activitypub-collection-loader @CssClass">
    @if (CollectionUrl != null)
    {
        @if (isLoading && !items.Any())
        {
            @if (LoadingTemplate != null)
            {
                @LoadingTemplate
            }
            else
            {
                <div class="loading-placeholder">Loading...</div>
            }
        }

        @if (items.Any())
        {
            @if (UseVirtualization)
            {
                <Virtualize Items="@items" ItemSize="@ItemSize" OverscanCount="@OverscanCount" Context="item">
                    @if (ItemTemplate != null)
                    {
                        @ItemTemplate(item)
                    }
                    else
                    {
                        <div class="collection-item">@item?.ToString()</div>
                    }
                </Virtualize>
            }
            else
            {
                @foreach (var item in items)
                {
                    @if (ItemTemplate != null)
                    {
                        @ItemTemplate(item)
                    }
                    else
                    {
                        <div class="collection-item">@item?.ToString()</div>
                    }
                }
            }
        }
        else if (!isLoading)
        {
            @if (EmptyTemplate != null)
            {
                @EmptyTemplate
            }
            else
            {
                <div class="empty-content">No items found</div>
            }
        }

        @if (hasMore)
        {
            <div @ref="sentinelRef" class="load-sentinel">
                @if (isLoading && items.Any())
                {
                    @if (LoadingTemplate != null)
                    {
                        @LoadingTemplate
                    }
                    else
                    {
                        <div class="loading-placeholder">Loading...</div>
                    }
                }
            </div>
        }

        @if (error != null && ErrorTemplate != null)
        {
            @ErrorTemplate(error)
        }
    }
</div>

@code {
    private List<TItem> items = new();
    private bool isLoading;
    private bool hasMore = true;
    private string? error;
    private string? activeCollectionUrl;
    private IAsyncEnumerator<TItem>? enumerator;

    private ElementReference sentinelRef;
    private IJSObjectReference? jsModule;
    private IJSObjectReference? jsObserver;
    private DotNetObjectReference<CollectionLoader<TItem>>? dotNetRef;
    private bool setupObserverAfterRender;

    [Parameter]
    public Uri? CollectionUrl { get; set; }

    [Parameter]
    public int PageSize { get; set; } = 20;

    /// <summary>
    /// When true (default) renders loaded items via the Virtualize component for efficient DOM rendering.
    /// </summary>
    [Parameter]
    public bool UseVirtualization { get; set; } = true;

    [Parameter]
    public float ItemSize { get; set; } = 150f;

    [Parameter]
    public int OverscanCount { get; set; } = 3;

    [Parameter]
    public bool EnableCaching { get; set; } = true;

    [Parameter]
    public string? CssClass { get; set; }

    [Parameter]
    public RenderFragment<TItem>? ItemTemplate { get; set; }

    [Parameter]
    public RenderFragment? LoadingTemplate { get; set; }

    [Parameter]
    public RenderFragment? EmptyTemplate { get; set; }

    [Parameter]
    public RenderFragment<string>? ErrorTemplate { get; set; }

    [Parameter]
    public EventCallback<IEnumerable<TItem>> OnItemsLoaded { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (CollectionUrl?.ToString() == activeCollectionUrl)
            return;

        await ResetAsync();

        if (CollectionUrl != null)
            await LoadNextPageAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (jsModule == null)
        {
            jsModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./_content/Broca.ActivityPub.Components/collection-loader.js");
            dotNetRef = DotNetObjectReference.Create(this);
        }

        if (setupObserverAfterRender && hasMore)
        {
            setupObserverAfterRender = false;
            await AttachObserverAsync();
        }
    }

    private async Task AttachObserverAsync()
    {
        if (jsModule == null || dotNetRef == null) return;

        if (jsObserver != null)
        {
            await jsModule.InvokeVoidAsync("disconnectObserver", jsObserver);
            await jsObserver.DisposeAsync();
            jsObserver = null;
        }

        jsObserver = await jsModule.InvokeAsync<IJSObjectReference>(
            "observeSentinel", sentinelRef, dotNetRef);
    }

    [JSInvokable]
    public async Task OnSentinelVisible()
    {
        if (!isLoading && hasMore)
            await LoadNextPageAsync();
    }

    private async Task LoadNextPageAsync()
    {
        if (isLoading || !hasMore || CollectionUrl == null) return;

        isLoading = true;
        error = null;
        StateHasChanged();

        try
        {
            enumerator ??= Client.GetCollectionAsync<TItem>(CollectionUrl).GetAsyncEnumerator();

            var newItems = new List<TItem>();
            for (var i = 0; i < PageSize; i++)
            {
                if (!await enumerator.MoveNextAsync())
                {
                    hasMore = false;
                    break;
                }
                newItems.Add(enumerator.Current);
            }

            items.AddRange(newItems);

            if (OnItemsLoaded.HasDelegate && newItems.Count > 0)
                await OnItemsLoaded.InvokeAsync(newItems);
        }
        catch (Exception ex)
        {
            error = $"Failed to load items: {ex.Message}";
            hasMore = false;
        }
        finally
        {
            isLoading = false;
            setupObserverAfterRender = hasMore;
            StateHasChanged();
        }
    }

    private async Task ResetAsync()
    {
        activeCollectionUrl = CollectionUrl?.ToString();
        items.Clear();
        hasMore = true;
        error = null;
        setupObserverAfterRender = true;

        if (enumerator != null)
        {
            await enumerator.DisposeAsync();
            enumerator = null;
        }
    }

    public async Task RefreshAsync()
    {
        await ResetAsync();
        if (CollectionUrl != null)
            await LoadNextPageAsync();
    }

    public void ClearCache() { }

    public IReadOnlyList<TItem> GetItems() => items.AsReadOnly();

    public bool IsLoading => isLoading;

    public async ValueTask DisposeAsync()
    {
        if (enumerator != null)
            await enumerator.DisposeAsync();

        if (jsModule != null && jsObserver != null)
        {
            try { await jsModule.InvokeVoidAsync("disconnectObserver", jsObserver); } catch { }
            await jsObserver.DisposeAsync();
        }

        if (jsModule != null)
        {
            try { await jsModule.DisposeAsync(); } catch { }
        }

        dotNetRef?.Dispose();
    }
}
